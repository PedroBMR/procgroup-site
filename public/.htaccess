# Configuração de servidor para a Hostinger (Apache/cPanel).
#
# Fica em public/ porque o Astro copia essa pasta como está para a raiz do
# build — então este arquivo chega em public_html junto com o site.
#
# ATENÇÃO: nada aqui vale no GitHub Pages, que ignora .htaccess. Só entra em
# vigor no deploy para a Hostinger.

# ---------------------------------------------------------------------------
# Página de erro
# ---------------------------------------------------------------------------
# Gerada por src/pages/404.astro. O caminho pressupõe o site na RAIZ do domínio,
# que é o estado de produção (base: '/'). Enquanto o build sair com
# base: '/procgroup-site', ajuste para /procgroup-site/404.html.
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------------
# HTTPS
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Canonicalização apex <-> www: NÃO habilitada de propósito.
# O hreflang e o canonical do site usam www.procgroup.com.br, mas o painel da
# Hostinger pode já estar redirecionando por conta própria — duas regras na
# mesma direção geram loop. Confirme no hPanel antes de descomentar.
#
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_HOST} ^procgroup\.com\.br$ [NC]
#   RewriteRule ^ https://www.procgroup.com.br%{REQUEST_URI} [L,R=301]
# </IfModule>

# ---------------------------------------------------------------------------
# Cabeçalhos de segurança
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Impede o navegador de "adivinhar" o tipo do arquivo e executar como script
  # algo que foi servido como outra coisa.
  Header always set X-Content-Type-Options "nosniff"

  # Não vaza o caminho completo da página de origem para sites externos.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Bloqueia clickjacking. frame-ancestors (abaixo) cobre navegadores modernos;
  # este fica para os antigos.
  Header always set X-Frame-Options "SAMEORIGIN"

  # Recursos que este site nunca usa.
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"

  # HSTS: só ative depois de confirmar que TODOS os subdomínios servem HTTPS —
  # o navegador passa a recusar HTTP por 1 ano e não há como voltar atrás rápido.
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # CSP parcial, deliberadamente SEM script-src.
  #
  # O Astro embute scripts de componentes como <script type="module"> inline
  # (menu do header, StatCounter, e o IIFE de /evento) — 68 blocos no build
  # atual. Um script-src 'self' quebraria todos eles, e um script-src
  # 'unsafe-inline' seria proteção de fachada. As diretivas abaixo, porém, não
  # dependem disso e valem por si:
  #   frame-ancestors  clickjacking
  #   base-uri         impede injetar <base> e sequestrar caminhos relativos
  #   form-action      impede que um POST seja desviado para outro domínio
  #   object-src       mata <object>/<embed>
  # Para ganhar script-src, seria preciso externalizar esses scripts inline ou
  # gerar hashes no build. Registrado no ROADMAP.
  Header always set Content-Security-Policy "frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Tudo em /_astro/ tem hash de conteúdo no nome: se o conteúdo muda, o nome
  # muda. Pode ser cacheado para sempre.
  <FilesMatch "\.(js|css|woff2?)$">
    <If "%{REQUEST_URI} =~ m#^/_astro/#">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
  </FilesMatch>

  # O HTML é o que aponta para os assets com hash — precisa ser revalidado,
  # senão o visitante fica preso numa versão antiga da página.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# ---------------------------------------------------------------------------
# Compressão
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json application/xml \
    image/svg+xml application/ld+json
</IfModule>

# ---------------------------------------------------------------------------
# Exposição desnecessária
# ---------------------------------------------------------------------------
# Sem listagem de diretório quando falta um index.
Options -Indexes

# Arquivos ocultos e de configuração nunca devem ser servidos.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
