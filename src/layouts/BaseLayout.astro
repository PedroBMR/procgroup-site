---
import TopBar from "../components/TopBar.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../utils/url";
import { getLangFromUrl, useTranslations, logicalPath, localePath, isSingleVersionPath } from "../i18n/utils";
import { locales, defaultLocale, htmlLangAttr, ogLocaleAttr } from "../i18n/config";
import "../styles/tokens.css";
import "../styles/base.css";

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  // PNG, não SVG: Facebook, LinkedIn e WhatsApp não renderizam SVG em
  // og:image — o card saía sem imagem nenhuma. Gerado por scripts/gerar-og.mjs
  // a partir de src/assets/og-default.svg.
  ogImage = "/og-default.png",
  schema,
  noIndex = false,
} = Astro.props;

const siteName = "Proc Group";
const siteUrl = "https://www.procgroup.com.br";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// path comes from Astro.url.pathname by default, which already includes the
// GitHub Pages base prefix (e.g. /procgroup-site). siteUrl is the future
// custom domain, which will serve from root, so strip the base before
// building canonical/og URLs.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalPath = base && path.startsWith(base) ? path.slice(base.length) || "/" : path;
const canonical = new URL(canonicalPath, siteUrl).toString();

// A imagem social é o único caso que NÃO pode usar siteUrl: o canonical aponta
// para o domínio futuro (www.procgroup.com.br), que ainda não serve os arquivos
// — /og-default.png dá 404 lá. Um card compartilhado hoje sairia sem imagem.
// Por isso o og:image é montado contra a origem real de deploy (Astro.site +
// base), que o Astro mantém em sincronia com o host atual (github.io). Quando o
// domínio próprio entrar no ar, basta ajustar `site`/`base` no astro.config.
// As capas do blog chegam já com o prefixo de base (astro:assets); removemos e
// recolocamos para não duplicar.
const ogPath = base && ogImage.startsWith(base) ? ogImage.slice(base.length) : ogImage;
const deployOrigin = Astro.site ?? new URL(siteUrl);
const ogImageUrl = new URL(base + ogPath, deployOrigin).toString();

// i18n: idioma da URL + versões alternativas da página em cada idioma (hreflang).
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const htmlLang = htmlLangAttr[lang];
const ogLocale = ogLocaleAttr[lang];
const logical = logicalPath(Astro.url);
// Páginas de versão única (blog, 404) não têm equivalente em outro idioma.
// Emitir hreflang apontando para /en/... e /es/... gerava alternativas que dão
// 404 — e o Google descarta o cluster inteiro quando isso acontece. Com uma
// única versão, o correto é não declarar hreflang nenhum.
const singleVersion = isSingleVersionPath(logical);
const alternates = singleVersion
  ? []
  : locales.map((l) => ({
      lang: l,
      hrefLang: htmlLangAttr[l],
      href: new URL(localePath(logical, l), siteUrl).toString(),
    }));
const xDefault = singleVersion ? null : new URL(localePath(logical, defaultLocale), siteUrl).toString();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Proc Group",
  url: siteUrl,
  logo: `${siteUrl}/brand/mark-red.webp`,
  description:
    "Plataforma de Inteligência Artificial, Visão Computacional e Infraestrutura de TI para cidades, empresas e indústrias.",
  foundingDate: "2014",
  email: "comercial@procgroup.com.br",
  telephone: "+55-46-3224-3532",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Caetano Munhoz da Rocha, 480",
    addressLocality: "Pato Branco",
    addressRegion: "PR",
    addressCountry: "BR",
  },
};

const schemaList = Array.isArray(schema) ? schema : schema ? [schema] : [];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Scroll-reveal starts elements at opacity:0 and relies on the JS observer
        below to show them. If JS never runs, force everything visible so the
        page is never left blank. */}
    <noscript><style>[data-reveal]{opacity:1 !important;transform:none !important;}</style></noscript>
    <link rel="icon" type="image/webp" href={withBase("/brand/mark-red.webp")} />
    <link rel="apple-touch-icon" href={withBase("/brand/mark-red.webp")} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hrefLang} href={a.href} />)}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Pesos pedidos = pesos usados. Barlow 900 e Space Grotesk 500 não
        aparecem em lugar nenhum do CSS (conferido por varredura de
        font-weight em src/), então eram dois arquivos baixados à toa. */}
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Space+Grotesk:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {schemaList.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <a href="#main" class="visually-hidden">{t.common.skipLink}</a>
    <TopBar />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <script>
      import "../scripts/motion.ts";
    </script>
  </body>
</html>
