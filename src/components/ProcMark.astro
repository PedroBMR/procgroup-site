---
// Marca da Proc = o ícone EXATO do favicon do site antigo (procgroup.com.br):
// o arquivo real public/brand/mark-red.webp, usado como está — sem redesenhar
// e sem recortar.
import { withBase } from "../utils/url";

interface Props {
  size?: number;
  class?: string;
  alt?: string;
}
const { size = 24, class: className = "", alt = "Proc" } = Astro.props;
---

<img
  class={className}
  src={withBase("/brand/mark-red.webp")}
  width={size}
  height={size}
  alt={alt}
  style={`width:${size}px;height:${size}px;object-fit:contain;display:inline-block;`}
/>
