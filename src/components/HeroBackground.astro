---
// Fundo do hero da Home — "constelação neural" 3D em three.js: um campo de
// partículas com profundidade, ligadas por linhas finas que reagem ao mouse
// (paralaxe + rotação lenta), nas cores da marca. Tema: IA / visão computacional.
//
// Resiliente: o SSR entrega o gradiente + grid (funciona sem JS). O canvas por
// cima recebe a constelação; se WebGL falhar ou o usuário preferir menos
// movimento, fica só o gradiente. O <canvas> é decorativo (aria-hidden).
---

<div class="hero-background" aria-hidden="true" data-parallax="-0.08" data-parallax-start="top top">
  <span class="grid-layer"></span>
  <canvas class="neural-canvas" data-neural></canvas>
  <span class="hero-veil"></span>
</div>

<style>
  .hero-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% 0%, var(--navy-800) 0%, var(--navy-950) 70%);
  }
  .grid-layer {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(85% 65% at 50% 40%, black 40%, transparent 100%);
  }
  .neural-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Véu sutil para manter o texto do hero legível sobre a constelação. */
  .hero-veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(100deg, rgba(6,10,20,0.78) 0%, rgba(6,10,20,0.35) 42%, transparent 70%),
      linear-gradient(0deg, var(--navy-950) 0%, transparent 26%);
  }
</style>

<script>
  // O three.js pesa mais que todo o resto do JS do site somado, e serve só a
  // este fundo decorativo (aria-hidden). Carregar sob demanda evita o download
  // para quem pediu prefers-reduced-motion ou não tem WebGL — que nunca veriam
  // a animação — e tira o peso do caminho crítico da home.
  // A implementação vive em ../scripts/neuralField.ts para que os imports do
  // three sejam nomeados e o bundler consiga podar a biblioteca.
  const canvas = document.querySelector<HTMLCanvasElement>("canvas[data-neural]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canvas && !reduce && hasWebGL()) {
    import("../scripts/neuralField")
      .then(({ initNeural }) => initNeural(canvas))
      .catch(() => {
        // Falhou o download ou a criação do contexto — segue só com o gradiente
        // e o grid entregues pelo SSR, que já formam o fundo completo.
      });
  }

  /** Confere antes de baixar, para não puxar a biblioteca à toa. */
  function hasWebGL(): boolean {
    try {
      const c = document.createElement("canvas");
      return !!(c.getContext("webgl2") || c.getContext("webgl"));
    } catch {
      return false;
    }
  }
</script>