---
import { getLangFromUrl } from "../i18n/utils";
import { usePages } from "../i18n/pages";

interface Props {
  title?: string;
}
const lang = getLangFromUrl(Astro.url);
const c = usePages(lang).contactChannels;
const { title = c.defaultTitle } = Astro.props;
---

<aside class="contact-info">
  <h2>{title}</h2>
  <p><strong>{c.email}:</strong> comercial@procgroup.com.br</p>
  <p><strong>{c.phone}:</strong> +55 46 3224-3532</p>
  <p><strong>{c.whatsapp}:</strong> +55 46 99141-1324</p>
  <p><strong>{c.address}:</strong> {c.addressValue}</p>
  <p><strong>{c.hours}:</strong> {c.hoursValue}</p>
  <p><strong>{c.alsoIn}:</strong> {c.alsoInValue}</p>
</aside>

<style>
  .contact-info { background: var(--color-bg-alt); border-radius: var(--radius-md); padding: var(--space-8); max-width: 420px; }
  .contact-info h2 { font-size: var(--fs-lg); }
  .contact-info p { margin-top: var(--space-3); font-size: var(--fs-sm); color: var(--color-text-muted); }
</style>
