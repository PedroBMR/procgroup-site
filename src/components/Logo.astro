---
interface Props {
  variant?: "navy" | "white";
  height?: number;
}
const { variant = "navy", height = 34 } = Astro.props;
const ratio = 234 / 74;
const width = Math.round(height * ratio);
---

{
  variant === "white" ? (
    <img
      src="/brand/logo-white.png"
      alt="Proc Group"
      width={width}
      height={height}
      style={`height:${height}px;width:auto;`}
    />
  ) : (
    <span
      class="logo-mask"
      role="img"
      aria-label="Proc Group"
      style={`--logo-h:${height}px; --logo-w:${width}px;`}
    />
  )
}

<style>
  .logo-mask {
    display: inline-block;
    height: var(--logo-h);
    width: var(--logo-w);
    background-color: var(--navy-900);
    -webkit-mask: url("/brand/logo-white.png") center / contain no-repeat;
    mask: url("/brand/logo-white.png") center / contain no-repeat;
  }
</style>
