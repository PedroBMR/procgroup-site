---
import { withBase } from "../utils/url";

interface Props {
  variant?: "navy" | "white";
  height?: number;
}
const { variant = "navy", height = 34 } = Astro.props;
const ratio = 234 / 74;
const width = Math.round(height * ratio);
---

{
  variant === "white" ? (
    <img
      src={withBase("/brand/logo-white.png")}
      alt="Proc Group"
      width={width}
      height={height}
      style={`height:${height}px;width:auto;`}
    />
  ) : (
    <span
      class="logo-mask"
      role="img"
      aria-label="Proc Group"
      style={`--logo-h:${height}px; --logo-w:${width}px; --logo-src:url("${withBase("/brand/logo-white.png")}");`}
    />
  )
}

<style>
  .logo-mask {
    display: inline-block;
    height: var(--logo-h);
    width: var(--logo-w);
    background-color: var(--navy-900);
    /* A URL vem por custom property, definida no elemento com withBase(): um
       url() escrito aqui ignoraria o base path do projeto e apontaria para
       /brand/... na raiz do domínio, dando 404 sob /procgroup-site. */
    -webkit-mask: var(--logo-src) center / contain no-repeat;
    mask: var(--logo-src) center / contain no-repeat;
  }
</style>
