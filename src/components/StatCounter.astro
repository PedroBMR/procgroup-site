---
import type { Stat } from "../data/stats";
interface Props extends Stat {}
const { value, suffix = "", label } = Astro.props;
---

<div class="stat" data-reveal>
  <p class="stat-value" data-count={value} data-suffix={suffix}>{value}{suffix}</p>
  <p class="stat-label">{label}</p>
</div>

<style>
  .stat-value {
    font-size: var(--fs-3xl);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .stat-label {
    margin-top: var(--space-1);
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.7);
  }
</style>

<script>
  const counters = document.querySelectorAll<HTMLElement>("[data-count]");
  // Quem pediu menos movimento fica com o número final que veio do servidor:
  // este era o único ponto animado do site que não checava a preferência.
  // Importante que a checagem venha ANTES do reset para "0" — zerar e não
  // animar deixaria os contadores em zero na tela.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const animate = (el: HTMLElement) => {
    const target = parseFloat(el.dataset.count || "0");
    const suffix = el.dataset.suffix || "";
    const isDecimal = String(target).includes(".");
    const duration = 1400;
    const start = performance.now();
    const step = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = target * eased;
      el.textContent = (isDecimal ? current.toFixed(1) : Math.round(current).toString()) + suffix;
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  if (!reduce) {
    // Nada de zerar os contadores aqui. O código anterior zerava todos no load
    // e só restaurava quando o IntersectionObserver disparasse — então, até o
    // bloco entrar na tela, o visitante lia "0+" e "0%" no lugar de "200+" e
    // "99%". Se o observer nunca disparasse, ficava em zero para sempre.
    // Como o primeiro quadro de animate() já escreve 0, deixar o valor do
    // servidor até lá dá exatamente a mesma animação, sem essa janela.
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animate(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    counters.forEach((el) => io.observe(el));
  }
</script>
