---
const scenes = [
  { label: "Cidade Inteligente", tone: "1" },
  { label: "Centro de Operações", tone: "2" },
  { label: "Videomonitoramento", tone: "3" },
  { label: "Indústria 4.0", tone: "4" },
  { label: "Data Center", tone: "1" },
  { label: "Inteligência Artificial", tone: "2" },
];
---

<div class="hero-scenes" data-hero-scenes aria-hidden="true">
  {scenes.map((scene, i) => (
    <div class:list={["scene", `tone-${scene.tone}`, { active: i === 0 }]} data-scene>
      <span class="scene-grid"></span>
      <span class="scene-label">{scene.label}</span>
    </div>
  ))}
  <div class="scanline"></div>
</div>

<style>
  .hero-scenes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% 0%, var(--navy-800) 0%, var(--navy-950) 70%);
  }
  .scene {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.6s ease;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: var(--space-12);
  }
  .scene.active { opacity: 1; }
  .scene-label {
    position: relative;
    z-index: 2;
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }
  .scene-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(219,3,3,0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(219,3,3,0.16) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(85% 65% at 50% 40%, black 40%, transparent 100%);
    animation: drift 16s linear infinite;
  }
  .tone-1 .scene-grid { background-color: rgba(255,255,255,0.05); }
  .tone-2 .scene-grid { background-color: rgba(219,3,3,0.06); }
  .tone-3 .scene-grid { background-color: rgba(255,255,255,0.08); }
  .tone-4 .scene-grid { background-color: rgba(219,3,3,0.04); }

  @keyframes drift {
    from { background-position: 0 0, 0 0; }
    to { background-position: 44px 44px, 44px 44px; }
  }

  .scanline {
    position: absolute;
    left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, rgba(219,3,3,0.75), transparent);
    animation: scan 5s ease-in-out infinite;
  }
  @keyframes scan {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 1; }
    50% { top: 100%; opacity: 1; }
    60% { opacity: 0; }
    100% { top: 100%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-grid { animation: none; }
    .scanline { display: none; }
  }
</style>

<script>
  const scenes = document.querySelectorAll<HTMLElement>("[data-scene]");
  if (scenes.length > 1 && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let index = 0;
    setInterval(() => {
      scenes[index].classList.remove("active");
      index = (index + 1) % scenes.length;
      scenes[index].classList.add("active");
    }, 3200);
  }
</script>
