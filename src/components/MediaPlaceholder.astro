---
// Placeholder de mídia (imagem/vídeo) para os pontos onde ainda faltam os
// assets descritos pelo comercial. Mostra um quadro on-brand + o briefing de
// arte (colapsável). Quando o arquivo real existir, trocar este componente por
// <Image .../> ou <video>. Os prompts completos vivem em src/data/mediaBriefs.ts
// e no BRIEFING-IMAGENS.md da raiz do projeto.
import type { Locale } from "../i18n/config";

interface Props {
  kind: "video" | "image";
  caption: string;
  prompt: string;
  lang?: Locale;
  color?: string;
}
const { kind, caption, prompt, lang = "pt", color = "var(--red-500)" } = Astro.props;

const L = {
  pt: { image: "Imagem", video: "Vídeo", ph: "arte em produção", brief: "Ver briefing da arte" },
  en: { image: "Image", video: "Video", ph: "artwork in production", brief: "Art brief (in PT)" },
  es: { image: "Imagen", video: "Video", ph: "arte en producción", brief: "Ver briefing del arte (PT)" },
}[lang];
const kindLabel = kind === "video" ? L.video : L.image;
---

<figure class="media-ph" style={`--accent: ${color}`}>
  <div class="media-ph-frame">
    <span class="media-ph-tag">
      <span class="media-ph-dot"></span>
      {kindLabel} · {L.ph}
    </span>
    <span class="media-ph-icon" aria-hidden="true">
      {kind === "video" ? (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2.5"></rect>
          <path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"></path>
        </svg>
      ) : (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2.5"></rect>
          <circle cx="8.5" cy="9.5" r="1.8"></circle>
          <path d="M4 17l5-5 4 4 3-3 4 4"></path>
        </svg>
      )}
    </span>
    <figcaption class="media-ph-caption">{caption}</figcaption>
  </div>
  <details class="media-ph-brief">
    <summary>{L.brief}</summary>
    <p>{prompt}</p>
  </details>
</figure>

<style>
  .media-ph { margin: 0; }
  .media-ph-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    border-radius: var(--radius-lg);
    border: 1.5px dashed color-mix(in srgb, var(--accent), var(--color-border-strong) 55%);
    background:
      radial-gradient(120% 130% at 85% 10%, color-mix(in srgb, var(--accent), transparent 82%), transparent 60%),
      linear-gradient(150deg, var(--navy-900), var(--navy-950));
    overflow: hidden;
    text-align: center;
  }
  .media-ph-tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 5px 12px;
    border-radius: var(--radius-pill);
  }
  .media-ph-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent), transparent 70%); }
  .media-ph-icon { color: color-mix(in srgb, var(--accent), white 24%); }
  .media-ph-icon svg { width: 56px; height: 56px; display: block; }
  .media-ph-caption {
    max-width: 44ch;
    padding-inline: var(--space-6);
    font-size: var(--fs-base);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  .media-ph-brief { margin-top: var(--space-4); }
  .media-ph-brief summary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    list-style: none;
    user-select: none;
  }
  .media-ph-brief summary::-webkit-details-marker { display: none; }
  .media-ph-brief summary::before {
    content: "";
    width: 8px; height: 8px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .media-ph-brief[open] summary::before { transform: rotate(45deg); }
  .media-ph-brief summary:hover { color: var(--color-text); }
  .media-ph-brief summary:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }
  .media-ph-brief p {
    margin: var(--space-3) 0 0;
    max-width: 82ch;
    font-size: var(--fs-sm);
    line-height: 1.6;
    color: var(--color-text-muted);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
  }
</style>
