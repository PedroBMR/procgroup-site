---
import { withBase } from "../utils/url";

const icons: Record<string, string> = {
  whatsapp: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Z" stroke="currentColor" stroke-width="1.6"/><path d="M8.4 8.6c.2-.5.5-.5.8-.5h.6c.2 0 .4 0 .6.5.2.5.7 1.7.7 1.8.1.1.1.3 0 .4-.1.2-.1.3-.3.5-.1.2-.3.3-.4.5-.2.1-.3.3-.1.6.2.4.8 1.3 1.8 2.1 1.2 1 2.2 1.4 2.6 1.5.2.1.4.1.5-.1.2-.2.6-.7.8-.9.2-.2.3-.2.5-.1.2.1 1.4.7 1.7.8.3.1.5.2.5.3.1.2.1.9-.2 1.7-.3.8-1.6 1.5-2.2 1.5-.6.1-1.3.1-2.1-.1-.5-.1-1.1-.3-1.9-.7-3.3-1.4-5.4-4.7-5.6-4.9-.2-.2-1.3-1.7-1.3-3.3 0-1.6.8-2.3 1.1-2.7Z" fill="currentColor"/></svg>`,
  ticket: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1.5a1.5 1.5 0 0 0 0 3V15a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1.5a1.5 1.5 0 0 0 0-3V9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M10 7v10" stroke="currentColor" stroke-width="1.6" stroke-dasharray="2 2"/></svg>`,
  briefcase: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="7" width="20" height="13" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="2"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h3l1-3h-4v-2c0-.6.4-1 1-1Z" fill="currentColor"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="2"/><circle cx="7.5" cy="8" r="1.4" fill="currentColor"/><path d="M7.5 11v6M11.5 17v-3.5c0-1.4 1-2.5 2.3-2.5s2.2 1 2.2 2.5V17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="5" width="20" height="14" rx="4" stroke="currentColor" stroke-width="2"/><path d="M10 9.5v5l4.5-2.5-4.5-2.5Z" fill="currentColor"/></svg>`,
};

interface UtilityLink {
  label: string;
  href: string;
  icon: string;
  external?: boolean;
  ariaLabel?: string;
}

const utilityLinks: UtilityLink[] = [
  {
    label: "+55 46 99141-1324",
    href: "https://wa.me/5546991411324",
    icon: "whatsapp",
    external: true,
    ariaLabel: "WhatsApp Vendas",
  },
  { label: "Suporte Técnico", href: "/suporte", icon: "ticket" },
  { label: "Trabalhe conosco", href: "/trabalhe-conosco", icon: "briefcase" },
];

const socialLinks = [
  { label: "Facebook", href: "https://www.facebook.com", icon: "facebook" },
  { label: "Instagram", href: "https://www.instagram.com", icon: "instagram" },
  { label: "LinkedIn", href: "https://www.linkedin.com", icon: "linkedin" },
  { label: "YouTube", href: "https://www.youtube.com", icon: "youtube" },
];
---

<div class="topbar">
  <div class="container topbar-inner">
    <ul class="utility-links">
      {utilityLinks.map((item) => (
        <li>
          <a
            href={item.external ? item.href : withBase(item.href)}
            aria-label={item.ariaLabel}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
          >
            <span class="icon" set:html={icons[item.icon]} />
            <span class="utility-label">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
    <ul class="social-links" aria-label="Redes sociais">
      {socialLinks.map((item) => (
        <li>
          <a href={item.href} aria-label={item.label} target="_blank" rel="noopener noreferrer">
            <span class="icon" set:html={icons[item.icon]} />
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 101;
    background: var(--navy-950);
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--fs-xs);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
  }
  .utility-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .utility-links a {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 40px;
    padding-inline: var(--space-1);
    font-weight: 600;
    transition: color var(--dur-fast) ease;
  }
  .utility-links a:hover { color: var(--white); }
  .icon { display: inline-flex; width: 14px; height: 14px; flex-shrink: 0; }
  .icon :global(svg) { width: 100%; height: 100%; }
  .utility-links .icon { color: var(--red-500); }

  .social-links { display: flex; align-items: center; gap: var(--space-2); }
  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--red-500);
    transition: background var(--dur-fast) ease, transform var(--dur-fast) ease;
  }
  .social-links a:hover { background: var(--red-600); transform: translateY(-1px); }
  .social-links .icon { width: 14px; height: 14px; color: var(--white); }

  @media (max-width: 780px) {
    .utility-label { display: none; }
    .utility-links { gap: var(--space-4); }
  }
</style>
