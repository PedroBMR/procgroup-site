---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Button from "../components/Button.astro";
import { getBusinessUnit, businessUnits } from "../data/businessUnits";
import { withBase } from "../utils/url";

interface Faq {
  q: string;
  a: string;
}

interface Props {
  slug: string;
  metaTitle: string;
  metaDescription: string;
  solutionsHeading: string;
  teamDescription: string;
  faqs: Faq[];
  finalCtaTitle: string;
  finalCtaText: string;
}

const {
  slug,
  metaTitle,
  metaDescription,
  solutionsHeading,
  teamDescription,
  faqs,
  finalCtaTitle,
  finalCtaText,
} = Astro.props;

const unit = getBusinessUnit(slug)!;
const otherUnits = businessUnits.filter((u) => u.slug !== unit.slug);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: unit.name,
    provider: { "@type": "Organization", name: "Proc Group" },
    description: unit.description,
    areaServed: "BR",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<BaseLayout title={metaTitle} description={metaDescription} schema={schema}>
  <div class="container">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: "Soluções", href: "/solucoes" },
        { label: unit.name, href: unit.href },
      ]}
    />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{unit.shortName}</p>
      <h1>{unit.name}</h1>
      <p class="lead">{unit.description}</p>
      <div class="hero-actions">
        <Button href="/contato?intent=demo" variant="primary" size="lg">Solicitar Demonstração</Button>
        <Button href="/plataforma-proc-ai" variant="secondary" size="lg">Ver a Plataforma Proc AI</Button>
      </div>
    </div>
  </section>

  <section class="section solutions-section" data-theme="light" style={`--unit-color: ${unit.color}`}>
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Soluções</p>
        <h2>{solutionsHeading}</h2>
      </div>
      <div class="solutions-grid">
        {unit.solutions.map((sol) => (
          <div class="solution-card" data-reveal>
            <span class="solution-dot"></span>
            <p>{sol}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <slot name="case-study" />

  <section class="section team-section">
    <div class="container team-grid">
      <div data-reveal>
        <p class="eyebrow">Time dedicado</p>
        <h2>{unit.team}</h2>
        <p class="lead">{teamDescription}</p>
      </div>
      <div class="team-visual" data-reveal style={`--unit-color: ${unit.color}`}></div>
    </div>
  </section>

  <section class="section faq-section" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Perguntas frequentes</p>
        <h2>Dúvidas sobre {unit.name}</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item" data-reveal>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section other-units">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Outras unidades de negócio</p>
        <h2>Explore outras soluções da Proc AI Platform</h2>
      </div>
      <div class="units-grid">
        {otherUnits.map((u) => (
          <a href={withBase(u.href)} class="unit-card" data-reveal style={`--unit-color: ${u.color}`}>
            <span class="unit-badge">{u.shortName}</span>
            <h3>{u.name}</h3>
            <p>{u.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner" data-reveal>
      <h2>{finalCtaTitle}</h2>
      <p>{finalCtaText}</p>
      <Button href="/contato?intent=demo" variant="primary" size="lg">Solicitar Demonstração</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }
  .hero-actions { display: flex; gap: var(--space-4); margin-top: var(--space-8); flex-wrap: wrap; }

  .section { padding-block: var(--space-16); }
  .section-header { max-width: 680px; margin-bottom: var(--space-12); }
  .section-header h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }

  .solutions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }
  .solution-card {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-weight: 600;
    transition: background var(--dur-fast) ease;
  }
  .solution-card:hover { background: var(--color-surface-hover); }
  .solution-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--unit-color); flex-shrink: 0; }

  .solutions-section { background: var(--color-bg); }
  .team-section { background: var(--navy-900); }
  .faq-section { background: var(--color-bg); }
  .team-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: center; }
  .team-grid h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }
  .team-visual {
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--unit-color), var(--navy-800));
    box-shadow: var(--shadow-lg);
  }

  .faq-list { display: flex; flex-direction: column; gap: var(--space-3); max-width: 760px; }
  .faq-item {
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .faq-item summary { font-weight: 700; cursor: pointer; color: var(--color-text); }
  .faq-item p { margin-top: var(--space-3); color: var(--color-text-muted); font-size: var(--fs-sm); }

  .units-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .unit-card {
    position: relative;
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), border-color var(--dur-fast) ease;
    overflow: hidden;
  }
  .unit-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--unit-color); }
  .unit-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: var(--unit-color); }
  .unit-badge { font-size: var(--fs-xs); font-weight: 700; color: var(--white); text-transform: uppercase; letter-spacing: 0.08em; }
  .unit-card h3 { margin-top: var(--space-2); font-size: var(--fs-lg); }
  .unit-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .final-cta {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-800));
    color: var(--white);
    text-align: center;
  }
  .final-cta-inner h2 { color: var(--white); font-size: var(--fs-3xl); max-width: 680px; margin-inline: auto; }
  .final-cta-inner p { margin-top: var(--space-4); color: rgba(255,255,255,0.75); }
  .final-cta-inner .btn { margin-top: var(--space-8); }

  @media (max-width: 980px) {
    .solutions-grid { grid-template-columns: 1fr 1fr; }
    .team-grid { grid-template-columns: 1fr; }
    .units-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .solutions-grid, .units-grid { grid-template-columns: 1fr; }
  }
</style>
