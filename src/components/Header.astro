---
import { getMainNav, getCtaNav } from "../data/nav";
import Button from "./Button.astro";
import Logo from "./Logo.astro";
import { getLangFromUrl, localizePath, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const common = useTranslations(lang).common;
const mainNav = getMainNav(lang);
const ctaNav = getCtaNav(lang);
const currentPath = Astro.url.pathname;
const homeHref = localizePath("/", lang);
const menuLabel = { pt: "Abrir menu", en: "Open menu", es: "Abrir menú" }[lang];
const homeAria = { pt: "Proc Group — página inicial", en: "Proc Group — home", es: "Proc Group — inicio" }[lang];
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a href={homeHref} class="logo" aria-label={homeAria}>
      <Logo variant="white" height={36} />
    </a>

    <nav class="main-nav" aria-label={common.navMain}>
      <ul>
        {mainNav.map((item) => (
          <li class:list={["nav-item", { "has-children": item.children }]}>
            <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
              {item.label}
              {item.children && <svg aria-hidden="true" focusable="false" class="chev" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>}
            </a>
            {item.children && (
              <div class="dropdown">
                {item.children.map((child) => (
                  <a href={child.href} class="dropdown-item">
                    <span class="dropdown-title">{child.label}</span>
                    <span class="dropdown-desc">{child.description}</span>
                  </a>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <Button href={ctaNav.href} variant="primary" size="md">{ctaNav.label}</Button>
    </div>

    <button
      class="menu-toggle"
      data-menu-toggle
      aria-label={menuLabel}
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" data-mobile-nav aria-label={menuLabel}>
    <ul>
      {mainNav.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
          {item.children && (
            <ul class="mobile-sub">
              {item.children.map((child) => <li><a href={child.href}>{child.label}</a></li>)}
            </ul>
          )}
        </li>
      ))}
      <li><a href={ctaNav.href} class="mobile-cta">{ctaNav.label}</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: var(--topbar-h);
    z-index: var(--z-sticky);
    background: rgba(6, 10, 20, 0.82);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--dur-fast) ease;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: var(--header-h);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .main-nav { flex: 1; display: flex; min-width: 0; }
  .main-nav > ul { display: flex; align-items: center; gap: var(--space-6); }
  .nav-item { position: relative; padding-block: var(--space-6); }
  .nav-item > a {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-300);
    white-space: nowrap;
    transition: color var(--dur-fast) ease;
  }
  .nav-item > a:hover, .nav-item > a[aria-current="page"] { color: var(--white); }
  .chev { transition: transform var(--dur-fast) ease; }
  .nav-item:hover .chev { transform: rotate(180deg); }

  .dropdown {
    position: absolute;
    top: 100%;
    left: -1rem;
    background: var(--surface-2);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    padding: var(--space-3);
    min-width: 300px;
    display: grid;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out), visibility var(--dur-fast);
  }
  .nav-item.has-children:hover .dropdown,
  .nav-item.has-children:focus-within .dropdown {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .dropdown-item { display: flex; flex-direction: column; gap: 2px; padding: var(--space-3); border-radius: var(--radius-sm); }
  .dropdown-item:hover { background: var(--surface-3); }
  .dropdown-title { font-weight: 700; font-size: var(--fs-sm); color: var(--white); }
  .dropdown-desc { font-size: var(--fs-xs); color: var(--ink-500); }

  .header-cta { flex-shrink: 0; }
  .menu-toggle { display: none; }

  @media (max-width: 1200px) {
    .main-nav, .header-cta { display: none; }
    .menu-toggle {
      display: flex; flex-direction: column; justify-content: center; gap: 5px;
      /* 44x44: é o controle principal de navegação no celular e estava em
         40x40. O header tem 68px de altura aqui, então cabe. */
      width: 44px; height: 44px; background: none; border: none; margin-left: auto;
      align-items: center;
    }
    .menu-toggle span { display: block; width: 22px; height: 2px; background: var(--white); transition: transform var(--dur-fast) ease, opacity var(--dur-fast) ease; }
    .header-inner { height: var(--header-h-mobile); }
  }

  .mobile-nav {
    display: none;
    max-height: 0;
    overflow: hidden;
    /* max-height: 0 + overflow: hidden RECORTA, mas não tira os ~12 links da
       ordem de tabulação: abaixo de 1200px o menu fechado é display:block e
       quem navega por teclado atravessava uma dúzia de links invisíveis depois
       do logo. visibility:hidden remove do foco — é o mesmo recurso que o
       dropdown do desktop já usa logo acima. */
    visibility: hidden;
    background: var(--surface-1);
    border-top: 1px solid var(--color-border);
    transition: max-height var(--dur-med) var(--ease-out), visibility var(--dur-med);
  }
  /* dvh, não vh: no celular vh ignora a barra de endereço. */
  .mobile-nav.is-open { visibility: visible; max-height: 80dvh; overflow-y: auto; }
  .mobile-nav ul { padding: var(--space-4) var(--space-6) var(--space-8); }
  .mobile-nav > ul > li > a { display: block; padding: var(--space-3) 0; font-weight: 700; font-size: var(--fs-lg); text-transform: uppercase; letter-spacing: 0.02em; color: var(--white); }
  .mobile-sub { padding-left: var(--space-4); }
  .mobile-sub a { display: block; padding: var(--space-2) 0; color: var(--ink-300); font-size: var(--fs-sm); }
  .mobile-cta { margin-top: var(--space-4); display: inline-block; background: var(--color-primary); color: var(--white) !important; padding: 0.8rem 1.6rem; border-radius: var(--radius-pill); font-weight: 700; }

  @media (max-width: 1200px) {
    .mobile-nav { display: block; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const mobileNav = document.querySelector<HTMLElement>("[data-mobile-nav]");

  const setOpen = (open: boolean) => {
    mobileNav?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
  };

  toggle?.addEventListener("click", () => {
    setOpen(!mobileNav?.classList.contains("is-open"));
  });

  // Esc fecha e devolve o foco ao botão — sem isso o foco fica solto no menu
  // que acabou de sumir.
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    if (!mobileNav?.classList.contains("is-open")) return;
    setOpen(false);
    toggle?.focus();
  });

  // Navegar para outra âncora da mesma página deixaria o menu aberto por cima
  // do conteúdo.
  mobileNav?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) setOpen(false);
  });
</script>
