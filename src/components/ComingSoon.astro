---
import { getLangFromUrl } from "../i18n/utils";
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}
const { eyebrow, title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const note = {
  pt: "Esta página faz parte da próxima fase da reformulação do site.",
  en: "This page is part of the next phase of the site revamp.",
  es: "Esta página forma parte de la próxima fase de la renovación del sitio.",
}[lang];
---

<section class="stub">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lead">{description}</p>
    <p class="note">{note}</p>
  </div>
</section>

<style>
  .stub { padding-block: var(--space-32); text-align: center; }
  .stub h1 { margin-top: var(--space-4); font-size: var(--fs-4xl); }
  .lead { margin: var(--space-6) auto 0; max-width: 560px; font-size: var(--fs-lg); color: var(--color-text-muted); }
  .note { margin-top: var(--space-8); font-size: var(--fs-xs); color: var(--color-text-faint); }
</style>
