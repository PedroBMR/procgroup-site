---
import { getBusinessUnits } from "../data/businessUnits";
import { getLangFromUrl } from "../i18n/utils";
import { usePages } from "../i18n/pages";
import { withBase } from "../utils/url";

const lang = getLangFromUrl(Astro.url);
const t = usePages(lang).mandala;
const businessUnits = getBusinessUnits(lang);

// Hub central: 4 arcos coloridos (um por unidade) ao redor de um núcleo "PROC AI".
// As soluções ficam listadas em colunas legíveis abaixo — layout mais claro e
// responsivo que o antigo sunburst de rótulos radiais.
const cx = 120;
const cy = 120;
const aInner = 64;
const aOuter = 92;
const gap = 6;
const span = 360 / businessUnits.length - gap;

function point(r: number, angleDeg: number) {
  const rad = ((angleDeg - 90) * Math.PI) / 180;
  return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
}

function arcPath(r0: number, r1: number, startDeg: number, endDeg: number) {
  const large = endDeg - startDeg > 180 ? 1 : 0;
  const a = point(r1, startDeg);
  const b = point(r1, endDeg);
  const c = point(r0, endDeg);
  const d = point(r0, startDeg);
  return `M ${a.x.toFixed(2)} ${a.y.toFixed(2)} A ${r1} ${r1} 0 ${large} 1 ${b.x.toFixed(2)} ${b.y.toFixed(2)} L ${c.x.toFixed(2)} ${c.y.toFixed(2)} A ${r0} ${r0} 0 ${large} 0 ${d.x.toFixed(2)} ${d.y.toFixed(2)} Z`;
}

const arcs = businessUnits.map((unit, i) => {
  const start = i * (span + gap);
  return { d: arcPath(aInner, aOuter, start, start + span), color: unit.color, name: unit.name };
});

// Marca Proc AI = o ícone EXATO do favicon do site (public/brand/mark-red.webp),
// usado como imagem, sem redesenhar e sem recortar.
---

<div class="platform-map">
  <div class="pm-hub" data-reveal>
    <svg viewBox="0 0 240 240" role="img" aria-label={t.ariaLabel}>
      {arcs.map((a) => <path d={a.d} fill={a.color} />)}
      <circle cx={cx} cy={cy} r={aInner - 8} class="pm-core" />
      <image href={withBase("/brand/mark-red.webp")} x={cx - 50} y="64" width="100" height="100" />
      <text x={cx} y={cy + 26} text-anchor="middle" class="pm-core-label">PROC AI</text>
    </svg>
  </div>

  <div class="pm-cols">
    {businessUnits.map((unit) => (
      <div class="pm-col" data-reveal style={`--u: ${unit.color}`}>
        <h3>{unit.name}</h3>
        <p class="pm-sn">{unit.shortName}</p>
        <ul class="pm-sols">
          {unit.solutions.map((sol) => <li>{sol}</li>)}
        </ul>
      </div>
    ))}
  </div>
</div>

<style>
  .platform-map { max-width: 1080px; margin-inline: auto; }

  .pm-hub { display: flex; justify-content: center; margin-bottom: var(--space-12); }
  .pm-hub svg { width: 220px; height: 220px; overflow: visible; }
  .pm-core { fill: var(--color-bg); stroke: var(--color-border); stroke-width: 1.5; }
  .pm-core-label {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 0.04em;
    fill: var(--color-text);
  }

  .pm-cols { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-4); }
  .pm-col {
    /* A seção que contém estas colunas também usa --color-bg-alt, então card e
       fundo mediam 1,00:1 e as quatro colunas desapareciam. A única separação
       era a borda, a 1,28:1 — abaixo do mínimo de 3:1 para elemento de
       interface. --color-surface é branco no tema claro e destaca a coluna. */
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    /* A barra do topo é a cor da unidade; navy sobre navy sumiria no tema
       escuro, então recebe o mesmo clareamento usado nos outros cards. */
    border-top: 3px solid color-mix(in srgb, var(--u), white 36%);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .pm-col h3 {
    display: flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    text-transform: uppercase;
    line-height: var(--lh-snug);
    color: var(--color-text);
  }
  .pm-col h3::before { content: ""; width: 11px; height: 11px; border-radius: 50%; background: var(--u); flex: none; }
  .pm-sn {
    margin: 2px 0 var(--space-4) calc(11px + var(--space-2));
    font-size: var(--fs-xs); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-text-faint);
  }
  .pm-sols { display: flex; flex-direction: column; gap: var(--space-2); }
  .pm-sols li {
    position: relative; padding-left: var(--space-4);
    font-size: var(--fs-sm); color: var(--color-text-muted); line-height: 1.35;
  }
  .pm-sols li::before {
    content: ""; position: absolute; left: 0; top: 0.5em;
    width: 6px; height: 6px; border-radius: 50%; background: var(--u); opacity: 0.55;
  }

  @media (max-width: 900px) { .pm-cols { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); } }
  @media (max-width: 520px) { .pm-cols { grid-template-columns: 1fr; } }
</style>
