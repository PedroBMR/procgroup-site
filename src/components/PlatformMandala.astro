---
import { businessUnits } from "../data/businessUnits";

const cx = 480;
const cy = 480;

const coreR = 74;
const ringAInner = 82;
const ringAOuter = 156;
const ringBInner = 162;
const ringBOuter = 258;
const ringCInner = 264;
const ringCOuter = 276;
const labelR = ringCOuter + 16;
const unitLabelR = (ringAInner + ringAOuter) / 2;

const unitGap = 3.2;
const segGap = 1.1;
const unitSpan = 360 / businessUnits.length - unitGap;

function point(r: number, angleDeg: number) {
  const rad = ((angleDeg - 90) * Math.PI) / 180;
  return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
}

function wedgePath(r0: number, r1: number, startDeg: number, endDeg: number) {
  const large = endDeg - startDeg > 180 ? 1 : 0;
  const a = point(r1, startDeg);
  const b = point(r1, endDeg);
  const c = point(r0, endDeg);
  const d = point(r0, startDeg);
  return `M ${a.x.toFixed(2)} ${a.y.toFixed(2)} A ${r1} ${r1} 0 ${large} 1 ${b.x.toFixed(2)} ${b.y.toFixed(2)} L ${c.x.toFixed(2)} ${c.y.toFixed(2)} A ${r0} ${r0} 0 ${large} 0 ${d.x.toFixed(2)} ${d.y.toFixed(2)} Z`;
}

function labelTransform(angleDeg: number, r: number) {
  const p = point(r, angleDeg);
  let rotate = angleDeg - 90;
  let anchor = "start";
  if (angleDeg > 180) {
    rotate = angleDeg - 270;
    anchor = "end";
  }
  return { x: p.x, y: p.y, rotate, anchor };
}

const unitWedges = businessUnits.map((unit, i) => {
  const start = i * (unitSpan + unitGap);
  const end = start + unitSpan;
  const mid = (start + end) / 2;

  const segCount = unit.solutions.length;
  const segSpan = (unitSpan - segGap * (segCount - 1)) / segCount;

  const segments = unit.solutions.map((sol, j) => {
    const segStart = start + j * (segSpan + segGap);
    const segEnd = segStart + segSpan;
    const segMid = (segStart + segEnd) / 2;
    return {
      name: sol,
      path: wedgePath(ringBInner, ringBOuter, segStart, segEnd),
      label: labelTransform(segMid, labelR),
      tick: { a: point(ringBOuter, segMid), b: point(ringCOuter, segMid) },
      shade: j % 2 === 0 ? 0.5 : 0.32,
    };
  });

  return {
    unit,
    start,
    end,
    mid,
    path: wedgePath(ringAInner, ringAOuter, start, end),
    outerPath: wedgePath(ringCInner, ringCOuter, start, end),
    label: labelTransform(mid, unitLabelR),
    segments,
  };
});
---

<div class="mandala-wrap" data-reveal>
  <svg viewBox="0 0 960 960" class="mandala" role="img" aria-label="Diagrama da Proc AI Platform e suas quatro unidades de negócio">
    <defs>
      <radialGradient id="mandalaGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--red-500)" stop-opacity="0.1" />
        <stop offset="100%" stop-color="var(--red-500)" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx={cx} cy={cy} r={ringCOuter + 60} fill="url(#mandalaGlow)" />

    {unitWedges.map((w) => (
      <g class="unit-group">
        <path d={w.path} fill={w.unit.color} opacity="0.92" />

        {w.segments.map((seg) => (
          <path d={seg.path} fill={w.unit.color} opacity={seg.shade} />
        ))}

        <path d={w.outerPath} fill={w.unit.color} opacity="0.35" />

        <text
          x={w.label.x}
          y={w.label.y}
          transform={`rotate(${w.label.rotate} ${w.label.x} ${w.label.y})`}
          text-anchor={w.label.anchor}
          class="unit-label"
        >
          {w.unit.shortName.toUpperCase()}
        </text>

        {w.segments.map((seg) => (
          <>
            <line x1={seg.tick.a.x} y1={seg.tick.a.y} x2={seg.tick.b.x} y2={seg.tick.b.y} class="tick" />
            <text
              x={seg.label.x}
              y={seg.label.y}
              transform={`rotate(${seg.label.rotate} ${seg.label.x} ${seg.label.y})`}
              text-anchor={seg.label.anchor}
              class="seg-label"
            >
              {seg.name}
            </text>
          </>
        ))}
      </g>
    ))}

    <circle cx={cx} cy={cy} r={coreR} class="mandala-core" />
    <g transform={`translate(${cx - 22}, ${cy - 30})`}>
      <path
        d="M7 7h14a9.5 9.5 0 0 1 0 19H14v9"
        fill="none"
        stroke="var(--red-500)"
        stroke-width="4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </g>
    <text x={cx} y={cy + 27} text-anchor="middle" class="core-label">PROC AI</text>
  </svg>
</div>

<style>
  .mandala-wrap {
    max-width: 800px;
    margin-inline: auto;
  }
  .mandala { width: 100%; height: auto; overflow: visible; }
  .mandala-core {
    fill: var(--color-bg-alt);
    stroke: var(--color-border-strong);
    stroke-width: 2;
  }
  .core-label {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 800;
    letter-spacing: 0.04em;
    fill: var(--color-text);
  }
  .unit-label {
    font-family: var(--font-sans);
    font-size: 14.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    fill: var(--white);
  }
  .seg-label {
    font-family: var(--font-sans);
    font-size: 11px;
    fill: var(--color-text);
  }
  .tick {
    stroke: var(--color-border-strong);
    stroke-width: 1;
  }
  .unit-group path { transition: opacity var(--dur-fast) ease; }

  @media (max-width: 640px) {
    .seg-label, .tick { display: none; }
  }
</style>
