---
// Diagrama animado "Como funciona a Proc AI Platform": um evento flui do hub
// central (PROC AI) para a unidade de negócio certa, com pulsos percorrendo as
// conexões. Rótulos ficam ABAIXO de cada nó (nomes longos não cabem dentro do
// círculo) e o SVG recebe width/height explícitos para não colapsar no tamanho
// intrínseco padrão de 300x150.
import { businessUnits } from "../data/businessUnits";

const steps = [
  { n: "01", title: "Captura", desc: "Câmeras e sensores registram um evento em tempo real." },
  { n: "02", title: "Análise", desc: "A Proc AI Platform classifica e entende o contexto." },
  { n: "03", title: "Direcionamento", desc: "A inteligência é roteada para a unidade especializada certa." },
  { n: "04", title: "Ação", desc: "Alerta ou resposta chega ao operador com contexto completo." },
];

const W = 1000;
const H = 440;
const hub = { x: W / 2, y: 74, r: 60 };
const nodeR = 40;
const nodeY = 300;
const nodeXs = [140, 380, 620, 860];

const nodes = businessUnits.map((unit, i) => {
  const parts = unit.name.split(" ");
  const l1 = parts.shift() as string;
  const l2 = parts.join(" ");
  return { unit, x: nodeXs[i], y: nodeY, l1, l2 };
});

function flowPath(nodeX: number) {
  const sY = hub.y + hub.r;
  const eY = nodeY - nodeR;
  const c1y = sY + (eY - sY) * 0.42;
  const c2y = sY + (eY - sY) * 0.82;
  return `M ${hub.x} ${sY} C ${hub.x} ${c1y}, ${nodeX} ${c2y}, ${nodeX} ${eY}`;
}

// Símbolo Proc AI (anel aberto + ondas) no hub, acima do texto.
const hmScale = 0.62;
const hmMarkCy = hub.y - 22;
const hmWaveCy = hub.y - 16;
const hmPt = (r: number, a: number, oy: number) => {
  const t = ((a - 90) * Math.PI) / 180;
  return `${(hub.x + r * Math.cos(t)).toFixed(2)} ${(oy + r * Math.sin(t)).toFixed(2)}`;
};
const hmArc = (r: number, s: number, e: number, oy: number) => {
  const large = e - s > 180 ? 1 : 0;
  return `M ${hmPt(r, s, oy)} A ${r} ${r} 0 ${large} 1 ${hmPt(r, e, oy)}`;
};
const hubRing = hmArc(16.5 * hmScale, 205, 515, hmMarkCy);
const hubWaves = [21, 15.5, 10].map((r) => hmArc(r * hmScale, 320, 400, hmWaveCy));
---

<div class="flow-wrap">
  <ol class="flow-steps">
    {steps.map((s) => (
      <li>
        <span class="step-n">{s.n}</span>
        <div>
          <p class="step-title">{s.title}</p>
          <p class="step-desc">{s.desc}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="diagram" data-reveal>
    <svg
      viewBox={`0 0 ${W} ${H}`}
      width={W}
      height={H}
      class="flow-svg"
      role="img"
      aria-label="Fluxo de um evento do hub central da Proc AI Platform até as quatro unidades de negócio"
    >
      {nodes.map((n) => (
        <path d={flowPath(n.x)} class="flow-line" style={`--unit-color: ${n.unit.color}`} />
      ))}

      {nodes.map((n, i) => (
        <circle r="8" class="pulse" style={`--unit-color: ${n.unit.color};`}>
          <animateMotion dur="3.4s" repeatCount="indefinite" begin={`${i * 0.7}s`} path={flowPath(n.x)} keyPoints="0;1" keyTimes="0;1" calcMode="linear" />
          <animate attributeName="opacity" dur="3.4s" repeatCount="indefinite" begin={`${i * 0.7}s`} values="0;1;1;1;0" keyTimes="0;0.08;0.5;0.9;1" />
        </circle>
      ))}

      <g class="hub">
        <circle cx={hub.x} cy={hub.y} r={hub.r} class="hub-ring">
          <animate attributeName="r" dur="3s" repeatCount="indefinite" values={`${hub.r};${hub.r + 20}`} />
          <animate attributeName="opacity" dur="3s" repeatCount="indefinite" values="0.5;0" />
        </circle>
        <circle cx={hub.x} cy={hub.y} r={hub.r} class="hub-core" />
        <path d={hubRing} fill="none" stroke="var(--white)" stroke-width="2.6" stroke-linecap="round" />
        {hubWaves.map((d) => <path d={d} fill="none" stroke="var(--red-500)" stroke-width="1.9" stroke-linecap="round" />)}
        <text x={hub.x} y={hub.y + 14} text-anchor="middle" class="hub-label">PROC AI</text>
        <text x={hub.x} y={hub.y + 30} text-anchor="middle" class="hub-sub">PLATFORM</text>
      </g>

      {nodes.map((n) => (
        <g class="node" style={`--unit-color: ${n.unit.color}`}>
          <circle cx={n.x} cy={n.y} r={nodeR} class="node-core" />
          <circle cx={n.x} cy={n.y} r="7" class="node-dot" />
          <text x={n.x} y={n.y + nodeR + 26} text-anchor="middle" class="node-label">
            <tspan x={n.x}>{n.l1}</tspan>
            {n.l2 && <tspan x={n.x} dy="20">{n.l2}</tspan>}
          </text>
        </g>
      ))}
    </svg>
  </div>
</div>

<style>
  .flow-wrap {
    display: grid;
    /* Explicit column so the single grid track fills the container instead of
       shrinking to the SVG's 300px intrinsic width (which made the diagram tiny). */
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-12);
  }

  .flow-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  .flow-steps li { display: flex; gap: var(--space-3); }
  .step-n { font-family: var(--font-display); font-size: var(--fs-xl); font-weight: 800; color: var(--color-primary); flex-shrink: 0; }
  .step-title { font-weight: 700; color: var(--color-text); }
  .step-desc { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .diagram { width: 100%; max-width: 860px; margin-inline: auto; }
  .flow-svg { width: 100%; height: auto; overflow: visible; }

  .flow-line { fill: none; stroke: var(--unit-color); stroke-opacity: 0.28; stroke-width: 2.5; }
  .pulse { fill: var(--unit-color); filter: drop-shadow(0 0 6px var(--unit-color)); }

  .hub-ring { fill: none; stroke: var(--red-500); stroke-width: 2; }
  .hub-core { fill: var(--navy-900); stroke: var(--red-500); stroke-width: 2.5; }
  .hub-label { font-family: var(--font-display); font-size: 27px; font-weight: 800; fill: var(--white); letter-spacing: 0.03em; }
  .hub-sub { font-family: var(--font-sans); font-size: 10px; font-weight: 600; letter-spacing: 0.34em; fill: rgba(255,255,255,0.6); }

  .node-core { fill: var(--unit-color); fill-opacity: 0.16; stroke: var(--unit-color); stroke-width: 2.5; }
  .node-dot { fill: var(--unit-color); }
  .node-label { font-family: var(--font-sans); font-size: 16px; font-weight: 700; fill: var(--color-text); }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
    .hub-ring { display: none; }
  }
  @media (max-width: 900px) {
    .flow-steps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .flow-steps { grid-template-columns: 1fr; }
    .node-label { font-size: 20px; }
  }
</style>
