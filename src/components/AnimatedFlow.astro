---
// Diagrama animado "Como funciona a Proc AI Platform" — reinterpretação do
// diagrama orquestrador visto em site de concorrente (aiquimist.com): em vez
// de um donut estático (ver PlatformMandala.astro), este mostra um evento
// fluindo de verdade do hub central para as 4 unidades de negócio, com
// pulsos animados percorrendo as conexões. Conteúdo e visual próprios da
// Proc — não reproduz texto nem código do concorrente, só a ideia de
// "mostrar o fluxo acontecendo" em vez de só listar features.
import { businessUnits } from "../data/businessUnits";

const steps = [
  { n: "01", title: "Captura", desc: "Câmeras e sensores registram um evento em tempo real." },
  { n: "02", title: "Análise", desc: "A Proc AI Platform classifica e entende o contexto." },
  { n: "03", title: "Direcionamento", desc: "A inteligência é roteada para a unidade especializada certa." },
  { n: "04", title: "Ação", desc: "Alerta ou resposta chega ao operador com contexto completo." },
];

const W = 1000;
const H = 420;
const hub = { x: W / 2, y: 68, r: 54 };
const nodeR = 42;
const nodeY = H - 78;
const nodeXs = [140, 380, 620, 860];

const nodes = businessUnits.map((unit, i) => ({
  unit,
  x: nodeXs[i],
  y: nodeY,
}));

function flowPath(nodeX: number) {
  const startY = hub.y + hub.r;
  const endY = nodeY - nodeR;
  const c1y = startY + (endY - startY) * 0.35;
  const c2y = startY + (endY - startY) * 0.75;
  return `M ${hub.x} ${startY} C ${hub.x} ${c1y}, ${nodeX} ${c2y - 40}, ${nodeX} ${endY}`;
}
---

<div class="flow-wrap">
  <ol class="flow-steps">
    {steps.map((s) => (
      <li>
        <span class="step-n">{s.n}</span>
        <div>
          <p class="step-title">{s.title}</p>
          <p class="step-desc">{s.desc}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="diagram" data-reveal>
    <svg viewBox={`0 0 ${W} ${H}`} class="flow-svg" role="img" aria-label="Fluxo de um evento do hub central da Proc AI Platform até as quatro unidades de negócio">
      {nodes.map((n) => (
        <path d={flowPath(n.x)} class="flow-line" style={`--unit-color: ${n.unit.color}`} />
      ))}
      {nodes.map((n, i) => (
        <circle r="5" class="pulse" style={`--unit-color: ${n.unit.color}; animation-delay: ${i * 0.9}s;`}>
          <animateMotion dur="3.6s" repeatCount="indefinite" begin={`${i * 0.9}s`} path={flowPath(n.x)} />
        </circle>
      ))}

      <g class="hub">
        <circle cx={hub.x} cy={hub.y} r={hub.r} class="hub-core" />
        <text x={hub.x} y={hub.y + 5} text-anchor="middle" class="hub-label">PROC AI</text>
      </g>

      {nodes.map((n) => (
        <g class="node" transform={`translate(${n.x}, ${n.y})`} style={`--unit-color: ${n.unit.color}`}>
          <circle r={nodeR} class="node-core" />
          <text y="-2" text-anchor="middle" class="node-label">{n.unit.shortName}</text>
        </g>
      ))}
    </svg>
  </div>
</div>

<style>
  .flow-wrap { display: grid; gap: var(--space-12); }

  .flow-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  .flow-steps li { display: flex; gap: var(--space-3); }
  .step-n { font-family: var(--font-display); font-size: var(--fs-xl); font-weight: 800; color: var(--color-primary); flex-shrink: 0; }
  .step-title { font-weight: 700; color: var(--color-text); }
  .step-desc { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .diagram { max-width: 900px; margin-inline: auto; }
  .flow-svg { width: 100%; height: auto; overflow: visible; }

  .flow-line { fill: none; stroke: var(--unit-color); stroke-opacity: 0.25; stroke-width: 2; }
  .pulse { fill: var(--unit-color); filter: drop-shadow(0 0 4px var(--unit-color)); }

  .hub-core { fill: var(--navy-900); stroke: var(--red-500); stroke-width: 2; }
  .hub-label { font-family: var(--font-display); font-size: 20px; font-weight: 800; fill: var(--white); letter-spacing: 0.02em; }

  .node-core { fill: var(--unit-color); opacity: 0.14; stroke: var(--unit-color); stroke-width: 2; }
  .node-label { font-family: var(--font-sans); font-size: 14px; font-weight: 700; fill: var(--color-text); }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
  }
  @media (max-width: 900px) {
    .flow-steps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .flow-steps { grid-template-columns: 1fr; }
  }
</style>
