---
import BusinessUnitTemplate from "../../components/BusinessUnitTemplate.astro";

const faqs = [
  {
    q: "Como a Proc apoia a segurança pública das cidades?",
    a: "Com uma plataforma integrada de videomonitoramento, reconhecimento facial, leitura de placas e analytics, conectada a um Centro Integrado de Operações operado por equipe especializada em segurança pública.",
  },
  {
    q: "As soluções se integram a sistemas já existentes no município?",
    a: "Sim. A Proc AI Platform possui APIs abertas para integração com câmeras, sensores e sistemas de gestão já utilizados pelo município.",
  },
  {
    q: "É possível monitorar escolas e mobilidade urbana na mesma plataforma?",
    a: "Sim, o monitoramento escolar e a mobilidade urbana fazem parte do mesmo ecossistema de Cidades Inteligentes, com dashboards unificados.",
  },
];

// Dados do case Pato 360° — combina fontes públicas oficiais verificadas em
// 2026-07-17 (prefeitura/câmara de Pato Branco, imprensa local) com
// confirmação direta do time da Proc sobre os municípios atendidos.
// NÚMEROS PODEM ESTAR DESATUALIZADOS em relação às notícias fonte — conferir
// com o time antes de publicar. Fontes:
// - https://patobranco.pr.gov.br/uso-da-tecnologia-e-parcerias-fortalecem-a-seguranca-publica-em-pato-branco/
// - https://www.patobranco.pr.leg.br/institucional/noticias/projeto-de-sistema-interligado-de-monitoramento-por-cameras-de-seguranca-e-apresentado-aos-vereadores
// - https://patobranco.pr.gov.br/wp-content/uploads/2024/08/... (edital CPSI nº 01/2024, Lei Complementar 182/2021)
const patoCities = ["Pato Branco", "Marmeleiro", "Sulina", "Chopinzinho", "Coronel Vivida"];
const patoStats = [
  { value: "5", label: "municípios atendidos via CPSI" },
  { value: "700+", label: "câmeras com IA em Pato Branco" },
  { value: "Lei 182/2021", label: "Marco Legal das Startups (modelo CPSI)" },
];
const patoFlow = [
  { n: "01", title: "Captura", desc: "Câmera pública ou privada registra a cena." },
  { n: "02", title: "Análise por IA", desc: "Reconhecimento facial, leitura de placas e detecção de áudio (gritos, vidro quebrado)." },
  { n: "03", title: "Correlação", desc: "Comparação com bases de veículos furtados e pessoas procuradas." },
  { n: "04", title: "Alerta", desc: "Notificação em tempo real à Polícia Militar, com localização e câmera de origem." },
];
const FLOW_W = 1000;
const FLOW_Y = 60;
const flowPath = `M 40 ${FLOW_Y} L ${FLOW_W - 40} ${FLOW_Y}`;
---

<BusinessUnitTemplate
  slug="cidades-inteligentes"
  metaTitle="Cidades Inteligentes — Segurança Pública com IA"
  metaDescription="Soluções de reconhecimento facial, leitura de placas, videomonitoramento inteligente e centro integrado de operações para governos e municípios."
  solutionsHeading="Tecnologias aplicadas à segurança pública e mobilidade urbana"
  teamDescription="Profissionais dedicados a projetos de segurança pública, com experiência em centros de operações, videomonitoramento inteligente e integração com forças de segurança."
  faqs={faqs}
  finalCtaTitle="Vamos tornar sua cidade mais segura e inteligente?"
  finalCtaText="Fale com um especialista em Cidades Inteligentes da Proc."
>
  <section slot="case-study" class="section pato-section" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Case em destaque</p>
        <h2>Pato 360° — rede de videomonitoramento inteligente no Sudoeste do Paraná</h2>
        <p class="lead">
          A Proc desenvolve a infraestrutura de software do Pato 360°, projeto público que integra
          reconhecimento facial, leitura de placas e análise de áudio a uma rede regional de câmeras,
          conectada ao Sistema Córtex do Ministério da Justiça e à Polícia Rodoviária Federal. O modelo
          já foi levado para outros municípios da região, todos contratados via CPSI (Contrato Público
          para Solução Inovadora, Lei Complementar 182/2021).
        </p>
        <ul class="pato-cities">
          {patoCities.map((city) => <li>{city}</li>)}
        </ul>
      </div>

      <div class="pato-stats">
        {patoStats.map((s) => (
          <div class="pato-stat" data-reveal>
            <p class="stat-value">{s.value}</p>
            <p class="stat-label">{s.label}</p>
          </div>
        ))}
      </div>

      <div class="pato-flow" data-reveal>
        <svg viewBox={`0 0 ${FLOW_W} 110`} class="flow-svg" role="img" aria-label="Fluxo de detecção do Pato 360, da captura da câmera ao alerta para a Polícia Militar">
          <path d={flowPath} class="flow-line" />
          <circle r="6" class="pulse">
            <animateMotion dur="3.5s" repeatCount="indefinite" path={flowPath} />
          </circle>
          {patoFlow.map((_, i) => {
            const x = 40 + (i * (FLOW_W - 80)) / (patoFlow.length - 1);
            return <circle cx={x} cy={FLOW_Y} r="7" class="node-dot" />;
          })}
        </svg>
        <div class="flow-steps">
          {patoFlow.map((s) => (
            <div class="flow-step">
              <span class="step-n">{s.n}</span>
              <p class="step-title">{s.title}</p>
              <p class="step-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <p class="pato-source">
        Fonte: dados públicos da Prefeitura e Câmara Municipal de Pato Branco/PR. Números sujeitos a
        atualização — confirmar com o time antes de publicar.
      </p>
    </div>
  </section>
</BusinessUnitTemplate>

<style>
  .pato-section { background: var(--color-bg); padding-block: var(--space-16); }
  /* <p> has no color rule in base.css (unlike h1-h4), so it inherits the
     already-resolved dark value from <body> instead of re-reading
     --color-text within this light-themed section. Must set explicitly. */
  .pato-section .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 720px; }
  .pato-section .section-header { max-width: 720px; margin-bottom: var(--space-12); }
  .pato-cities { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-6); }
  .pato-cities li {
    font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }
  .pato-stats {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6);
    margin-bottom: var(--space-12);
  }
  .pato-stat {
    text-align: center; padding: var(--space-6);
    background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md);
  }
  .stat-value { font-family: var(--font-display); font-size: var(--fs-3xl); font-weight: 800; color: var(--color-primary-dark); }
  .stat-label { margin-top: var(--space-1); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .pato-flow { max-width: 960px; margin-inline: auto; }
  .flow-svg { width: 100%; height: auto; overflow: visible; }
  .flow-line { stroke: var(--color-border-strong); stroke-width: 2; }
  .node-dot { fill: var(--color-bg); stroke: var(--color-primary); stroke-width: 2; }
  .pulse { fill: var(--color-primary); filter: drop-shadow(0 0 4px var(--color-primary)); }

  .flow-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-top: var(--space-4); }
  .step-n { font-family: var(--font-display); font-size: var(--fs-lg); font-weight: 800; color: var(--color-primary); }
  .step-title { margin-top: var(--space-1); font-weight: 700; color: var(--color-text); }
  .step-desc { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .pato-source { margin-top: var(--space-8); font-size: var(--fs-xs); color: var(--color-text-faint); text-align: center; }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
  }
  @media (max-width: 900px) {
    .pato-stats { grid-template-columns: 1fr; }
    .flow-steps { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .flow-steps { grid-template-columns: 1fr; }
  }
</style>
