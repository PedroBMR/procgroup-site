      "⚠️ PLACEHOLDER — los casos de abajo son ejemplos ilustrativos de estructura y formato, no resultados reales de clientes. Sustituir por casos verificados antes de publicar.",
    realTag: "Caso real",
    placeholderTag: "Ejemplo ilustrativo",
    blockProblem: "Problema",
    blockChallenge: "Desafío",
    blockSolution: "Solución",
    finalCtaTitle: "¿Quieres un resultado así en tu operación?",
    finalCtaText: "Habla con un especialista Proc y descubre la solución ideal para tu contexto.",
    items: [
      {
        unitSlug: "cidades-inteligentes",
        title: "Pato 360° — red de videovigilancia inteligente en el Sudoeste de Paraná",
        problem: "Red municipal de cámaras creciendo rápidamente, con necesidad de reconocimiento facial, lectura de placas y análisis de audio operando en tiempo real.",
        challenge: "Integrar cientos de cámaras públicas y privadas en una central única, replicando el modelo en otros municipios de la región.",
        solution: "Proc Group desarrolla la infraestructura de software del Pato 360°, llevado a Pato Branco, Marmeleiro, Sulina, Chopinzinho y Coronel Vivida vía CPSI (Contrato Público para Solución Innovadora, Ley 182/2021), integrado al Sistema Córtex y a la Policía Federal de Carreteras.",
        results: ["5 municipios atendidos vía CPSI", "700+ cámaras con IA en Pato Branco", "Alertas en tiempo real a la Policía Militar"],
        isReal: true,
        source: "Datos públicos de la Alcaldía/Concejo de Pato Branco/PR + confirmación directa del equipo de Proc sobre los municipios atendidos — verificar antes de publicar.",
      },
      {
        unitSlug: "seguranca-corporativa",
        title: "Control de acceso facial en un parque industrial",
        problem: "Torniquetes con tarjeta de acceso generando filas en los cambios de turno y vulnerabilidad al uso compartido de credenciales.",
        challenge: "Sustituir el control por tarjeta sin interrumpir la operación de la fábrica, manteniendo alta velocidad de paso en horas pico.",
        solution: "Reconocimiento facial integrado a los torniquetes existentes vía la API abierta de la Proc AI Platform, con fallback automático a los dispositivos antiguos durante la transición.",
        results: ["-70% tiempo de fila en el cambio de turno", "0 incidentes de uso compartido de credencial", "Implementación sin parada de producción"],
      },
      {
        unitSlug: "infraestrutura-de-ti",
        title: "Migración a nube híbrida con continuidad operativa",
        problem: "Infraestructura local antigua, sin redundancia, con riesgo de indisponibilidad en picos de demanda.",
        challenge: "Migrar cargas críticas a la nube sin interrumpir la operación del cliente, manteniendo compliance y gobernanza de datos.",
        solution: "Arquitectura de nube híbrida gestionada por el NOC de Proc, con monitoreo 24x7, backup automatizado y plan de continuidad probado.",
        results: ["99.9% de disponibilidad", "-45% costo de infraestructura", "Recuperación de desastres en minutos"],
      },
      {
        unitSlug: "ia-industrial",
        title: "Inspección visual automatizada en línea de producción",
        problem: "Inspección de calidad hecha manualmente, con alta variabilidad entre inspectores y baja trazabilidad de defectos.",
        challenge: "Automatizar la inspección sin reducir la velocidad de la línea, identificando defectos sutiles en tiempo real.",
        solution: "Cámaras de Edge AI instaladas en la línea existente, con modelos de visión artificial entrenados para los defectos específicos del proceso del cliente.",
        results: ["+18% de piezas aprobadas en la primera inspección", "Trazabilidad completa por pieza", "Detección en tiempo real en la línea"],
      },
    ],
  },
};

const t = casesI18n[lang];

// Placeholder de foto por case (a produzir). Caption localizado; prompt de arte
// em PT por segmento — consolidado em BRIEFING-IMAGENS.md.
const caseMediaCaption = { pt: "Foto do case — a produzir", en: "Case photo — to produce", es: "Foto del caso — a producir" }[lang];
const caseMediaPrompt: Record<string, string> = {
  "cidades-inteligentes":
    "Foto da operação Pato 360°: sala/Centro Integrado de Operações com video wall (mapas, alertas, reconhecimento facial, LPR), ou efetivo/viatura integrado. Navy + vermelho, tom de segurança pública. (Com autorização de uso.)",
  "seguranca-corporativa":
    "Foto de controle de acesso facial em ambiente corporativo/industrial (catraca ou terminal) e câmeras inteligentes; ao fundo, operador na central. Navy + vermelho.",
  "infraestrutura-de-ti":
    "Foto de data center / racks de servidores (corredor frio) ou equipe de NOC diante de dashboards. Iluminação azulada, navy + vermelho.",
  "ia-industrial":
    "Foto de linha de produção com câmeras industriais e inspeção por visão computacional (overlays de detecção). Ambiente industrial limpo, navy + vermelho.",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Cases Proc Group",
  description: t.metaDescription,
};
---

<BaseLayout title={tr.nav.cases} description={t.metaDescription} schema={schema}>
  <div class="container">
    <Breadcrumb
      items={[
        { label: tr.nav.home, href: localePath("/", lang) },
        { label: tr.nav.cases, href: localePath("/cases", lang) },
      ]}
    />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle}</h1>
      <p class="lead">{t.heroLead}</p>
      <p class="placeholder-banner">{t.placeholderBanner}</p>
    </div>
  </section>

  <section class="section cases-section" data-theme="light">
    <div class="container">
      <div class="cases-grid">
        {t.items.map((c) => {
          const unit = getBusinessUnit(c.unitSlug, lang)!;
          return (
            <article class="case-card" data-reveal style={`--unit-color: ${unit.color}`}>
              <div class="case-media">
                <MediaPlaceholder kind="image" caption={caseMediaCaption} prompt={caseMediaPrompt[c.unitSlug]} lang={lang} color={unit.color} />
              </div>
              {c.isReal ? (
                <span class="real-tag">{t.realTag}</span>
              ) : (
                <span class="placeholder-tag">{t.placeholderTag}</span>
              )}
              <span class="case-badge">{unit.shortName}</span>
              <h2>{c.title}</h2>

              <div class="case-block">
                <h3>{t.blockProblem}</h3>
                <p>{c.problem}</p>
              </div>
              <div class="case-block">
                <h3>{t.blockChallenge}</h3>
                <p>{c.challenge}</p>
              </div>
              <div class="case-block">
                <h3>{t.blockSolution}</h3>
                <p>{c.solution}</p>
              </div>

              <div class="case-results">
                {c.results.map((r) => <span class="result-pill">{r}</span>)}
              </div>

              {c.source && <p class="case-source">{c.source}</p>}
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner" data-reveal>
      <h2>{t.finalCtaTitle}</h2>
      <p>{t.finalCtaText}</p>
      <Button href={WHATSAPP_DEMO} variant="primary" size="lg" data-magnetic>{tr.solutions.ctaDemo}</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }

  .placeholder-banner {
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-5);
    max-width: 720px;
    background: rgba(255, 200, 0, 0.1);
    border: 1px dashed rgba(255, 200, 0, 0.5);
    border-radius: var(--radius-sm);
    color: #ffc800;
    font-size: var(--fs-sm);
    font-weight: 600;
  }

  .section { padding-block: var(--space-16); }
  .cases-section { background: var(--color-bg); }

  .cases-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: var(--space-8); }
  .case-card {
    position: relative;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }
  .case-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--unit-color); }
  .case-media { margin-bottom: var(--space-6); }
  .placeholder-tag {
    display: inline-block;
    margin-bottom: var(--space-3);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    background: rgba(180, 130, 0, 0.12);
    border: 1px dashed rgba(180, 130, 0, 0.6);
    color: #8a6200;
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .real-tag {
    display: inline-block;
    margin-bottom: var(--space-3);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    background: var(--color-success-bg);
    border: 1px solid rgba(22, 163, 74, 0.4);
    color: var(--color-success);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .case-source { margin-top: var(--space-6); font-size: 11px; color: var(--color-text-faint); }
  /* Esta seção é clara, e --unit-color pode ser o --red-500, que mede 4,49:1
     sobre ela — reprova AA por 0,01. Escurecer um pouco resolve sem mudar a
     leitura da cor (o resultado é praticamente o --red-600, que os tokens já
     usam como vermelho seguro em fundo claro). Nas unidades navy o escurecimento
     é inócuo, elas já passam com folga aqui. */
  .case-badge { display: block; font-size: var(--fs-xs); font-weight: 700; color: color-mix(in srgb, var(--unit-color), black 18%); text-transform: uppercase; letter-spacing: 0.08em; }
  .case-card h2 { margin-top: var(--space-3); font-size: var(--fs-xl); text-transform: none; font-family: var(--font-sans); }
  .case-block { margin-top: var(--space-6); }
  .case-block h3 { font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: 0.06em; color: color-mix(in srgb, var(--unit-color), black 18%); font-family: var(--font-sans); font-weight: 700; }
  .case-block p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }
  .case-results { margin-top: var(--space-6); display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .result-pill {
    font-size: var(--fs-xs); font-weight: 700;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .final-cta {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-800));
    color: var(--white);
    text-align: center;
  }
  .final-cta-inner h2 { color: var(--white); font-size: var(--fs-3xl); max-width: 680px; margin-inline: auto; }
  .final-cta-inner p { margin-top: var(--space-4); color: rgba(255,255,255,0.75); }
  .final-cta-inner .btn { margin-top: var(--space-8); }

  @media (max-width: 980px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
