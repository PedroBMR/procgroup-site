        results: ["5 municipalities served via CPSI", "700+ AI cameras in Pato Branco", "Real-time alerts to the Military Police"],
        isReal: true,
        source: "Public data from Pato Branco/PR City Hall and City Council + direct confirmation from the Proc team about the municipalities served — verify before publishing.",
      },
      {
        unitSlug: "seguranca-corporativa",
        title: "Facial access control at an industrial park",
        problem: "Card-based turnstiles creating queues at shift changes and vulnerability to credential sharing.",
        challenge: "Replacing card-based control without interrupting the factory's operation, keeping high throughput at peak times.",
        solution: "Facial recognition integrated into the existing turnstiles via the Proc AI Platform's open API, with automatic fallback to the legacy devices during the transition.",
