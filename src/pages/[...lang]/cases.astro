    finalCtaText: "Talk to a Proc specialist and find the right solution for your context.",
    items: [
      {
        unitSlug: "cidades-inteligentes",
        title: "Pato 360° — intelligent video-surveillance network in Southwest Paraná",
        problem: "A rapidly growing municipal camera network needing facial recognition, license-plate reading and audio analysis operating in real time.",
        challenge: "Integrating hundreds of public and private cameras into a single control center, replicating the model in other municipalities in the region.",
