---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Button from "../../components/Button.astro";
import MediaPlaceholder from "../../components/MediaPlaceholder.astro";
import { getBusinessUnit } from "../../data/businessUnits";
import { WHATSAPP_DEMO } from "../../data/contact";
import { useTranslations, localePath } from "../../i18n/utils";
import { defaultLocale, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}
const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);

interface CaseItem {
  unitSlug: string;
  title: string;
  problem: string;
  challenge: string;
  solution: string;
  results: string[];
  isReal?: boolean;
  source?: string;
}
interface CasesCopy {
  metaDescription: string;
  heroEyebrow: string;
  heroTitle: string;
  heroLead: string;
  placeholderBanner: string;
  realTag: string;
  placeholderTag: string;
  blockProblem: string;
  blockChallenge: string;
  blockSolution: string;
  finalCtaTitle: string;
  finalCtaText: string;
  items: CaseItem[];
}

const casesI18n: Record<Locale, CasesCopy> = {
  pt: {
    metaDescription:
      "Cases de sucesso da Proc Group: problema, desafio, solução e resultados em Cidades Inteligentes, Segurança Corporativa, Infraestrutura de TI e IA Industrial.",
