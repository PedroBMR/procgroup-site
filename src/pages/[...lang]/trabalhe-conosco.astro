---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Button from "../../components/Button.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import { usePages } from "../../i18n/pages";
import { defaultLocale, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}
const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);
const t = usePages(lang).trabalhe;
const mailHref = `mailto:comercial@procgroup.com.br?subject=${encodeURIComponent(t.mailSubject)}`;
---

<BaseLayout title={t.heroTitle} description={t.metaDescription}>
  <div class="container">
    <Breadcrumb items={[{ label: tr.nav.home, href: localePath("/", lang) }, { label: t.heroTitle, href: localePath("/trabalhe-conosco", lang) }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle}</h1>
      <p class="lead">{t.lead}</p>
      <div class="cta-row">
        <Button href={mailHref} variant="primary" size="lg" data-magnetic>{t.cta}</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-24); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 620px; }
  .cta-row { margin-top: var(--space-8); }
</style>
