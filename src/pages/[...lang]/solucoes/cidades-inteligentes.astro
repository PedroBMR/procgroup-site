---
import BusinessUnitTemplate from "../../../components/BusinessUnitTemplate.astro";
import { useTranslations } from "../../../i18n/utils";
import { defaultLocale, type Locale } from "../../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = (Astro.params.lang as Locale) || defaultLocale;
const p = useTranslations(lang).solutions.pages["cidades-inteligentes"];

// Case Pato 360° — cópia própria da página (não faz parte do template).
// Municípios são nomes próprios (não traduzem). Números sujeitos a atualização.
const patoCities = ["Pato Branco", "Marmeleiro", "Sulina", "Chopinzinho", "Coronel Vivida"];

const caseI18n: Record<Locale, {
  eyebrow: string;
  title: string;
  lead: string;
  stats: { value: string; label: string }[];
  flow: { n: string; title: string; desc: string }[];
  source: string;
  flowAria: string;
}> = {
  pt: {
    eyebrow: "Case em destaque",
    title: "Pato 360° — rede de videomonitoramento inteligente no Sudoeste do Paraná",
    lead: "A Proc desenvolve a infraestrutura de software do Pato 360°, projeto público que integra reconhecimento facial, leitura de placas e análise de áudio a uma rede regional de câmeras, conectada ao Sistema Córtex do Ministério da Justiça e à Polícia Rodoviária Federal. O modelo já foi levado para outros municípios da região, todos contratados via CPSI (Contrato Público para Solução Inovadora, Lei Complementar 182/2021).",
    stats: [
      { value: "5", label: "municípios atendidos via CPSI" },
      { value: "700+", label: "câmeras com IA em Pato Branco" },
      { value: "Lei 182/2021", label: "Marco Legal das Startups (modelo CPSI)" },
    ],
    flow: [
      { n: "01", title: "Captura", desc: "Câmera pública ou privada registra a cena." },
      { n: "02", title: "Análise por IA", desc: "Reconhecimento facial, leitura de placas e detecção de áudio (gritos, vidro quebrado)." },
      { n: "03", title: "Correlação", desc: "Comparação com bases de veículos furtados e pessoas procuradas." },
      { n: "04", title: "Alerta", desc: "Notificação em tempo real à Polícia Militar, com localização e câmera de origem." },
    ],
    source: "Fonte: dados públicos da Prefeitura e Câmara Municipal de Pato Branco/PR. Números sujeitos a atualização — confirmar com o time antes de publicar.",
    flowAria: "Fluxo de detecção do Pato 360, da captura da câmera ao alerta para a Polícia Militar",
  },
  en: {
    eyebrow: "Featured case",
    title: "Pato 360° — intelligent video-surveillance network in Southwest Paraná",
    lead: "Proc builds the software infrastructure of Pato 360°, a public project that integrates facial recognition, license-plate reading and audio analysis into a regional camera network, connected to the Brazilian Ministry of Justice's Córtex System and the Federal Highway Police. The model has already been extended to other municipalities in the region, all contracted via CPSI (Public Contract for Innovative Solutions, Complementary Law 182/2021).",
    stats: [
      { value: "5", label: "municipalities served via CPSI" },
      { value: "700+", label: "AI cameras in Pato Branco" },
      { value: "Law 182/2021", label: "Startups Legal Framework (CPSI model)" },
    ],
    flow: [
      { n: "01", title: "Capture", desc: "A public or private camera records the scene." },
      { n: "02", title: "AI Analysis", desc: "Facial recognition, license-plate reading and audio detection (screams, breaking glass)." },
      { n: "03", title: "Correlation", desc: "Matching against databases of stolen vehicles and wanted people." },
      { n: "04", title: "Alert", desc: "Real-time notification to the Military Police, with location and source camera." },
    ],
    source: "Source: public data from the City Hall and City Council of Pato Branco/PR, Brazil. Figures subject to update — confirm with the team before publishing.",
    flowAria: "Pato 360 detection flow, from camera capture to the alert sent to the Military Police",
  },
  es: {
    eyebrow: "Caso destacado",
    title: "Pato 360° — red de videovigilancia inteligente en el Sudoeste de Paraná",
    lead: "Proc desarrolla la infraestructura de software del Pato 360°, un proyecto público que integra reconocimiento facial, lectura de placas y análisis de audio en una red regional de cámaras, conectada al Sistema Córtex del Ministerio de Justicia y a la Policía Federal de Carreteras. El modelo ya se llevó a otros municipios de la región, todos contratados vía CPSI (Contrato Público para Solución Innovadora, Ley Complementaria 182/2021).",
    stats: [
      { value: "5", label: "municipios atendidos vía CPSI" },
      { value: "700+", label: "cámaras con IA en Pato Branco" },
      { value: "Ley 182/2021", label: "Marco Legal de las Startups (modelo CPSI)" },
    ],
    flow: [
      { n: "01", title: "Captura", desc: "Una cámara pública o privada registra la escena." },
      { n: "02", title: "Análisis por IA", desc: "Reconocimiento facial, lectura de placas y detección de audio (gritos, vidrio roto)." },
      { n: "03", title: "Correlación", desc: "Comparación con bases de vehículos robados y personas buscadas." },
      { n: "04", title: "Alerta", desc: "Notificación en tiempo real a la Policía Militar, con ubicación y cámara de origen." },
    ],
    source: "Fuente: datos públicos de la Alcaldía y el Concejo Municipal de Pato Branco/PR, Brasil. Cifras sujetas a actualización — confirmar con el equipo antes de publicar.",
    flowAria: "Flujo de detección del Pato 360, de la captura de la cámara a la alerta a la Policía Militar",
  },
};
const c = caseI18n[lang];

const FLOW_W = 1000;
const FLOW_Y = 60;
const flowPath = `M 40 ${FLOW_Y} L ${FLOW_W - 40} ${FLOW_Y}`;
---

<BusinessUnitTemplate
  slug="cidades-inteligentes"
  metaTitle={p.metaTitle}
  metaDescription={p.metaDescription}
  heroTitle={p.heroTitle}
  heroLead={p.heroLead}
  solutionsHeading={p.solutionsHeading}
  teamDescription={p.teamDescription}
  faqs={p.faqs}
  finalCtaTitle={p.finalCtaTitle}
  finalCtaText={p.finalCtaText}
>
  <section slot="case-study" class="section pato-section" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">{c.eyebrow}</p>
        <h2>{c.title}</h2>
        <p class="lead">{c.lead}</p>
        <ul class="pato-cities">
          {patoCities.map((city) => <li>{city}</li>)}
        </ul>
      </div>

      <div class="pato-stats">
        {c.stats.map((s) => (
          <div class="pato-stat" data-reveal>
            <p class="stat-value">{s.value}</p>
            <p class="stat-label">{s.label}</p>
          </div>
        ))}
      </div>

      <div class="pato-flow" data-reveal>
        <svg viewBox={`0 0 ${FLOW_W} 110`} class="flow-svg" role="img" aria-label={c.flowAria}>
          <path d={flowPath} class="flow-line" />
          <circle r="6" class="pulse">
            <animateMotion dur="3.5s" repeatCount="indefinite" path={flowPath} />
          </circle>
          {c.flow.map((_, i) => {
            const x = 40 + (i * (FLOW_W - 80)) / (c.flow.length - 1);
            return <circle cx={x} cy={FLOW_Y} r="7" class="node-dot" />;
          })}
        </svg>
        <div class="flow-steps">
          {c.flow.map((s) => (
            <div class="flow-step">
              <span class="step-n">{s.n}</span>
              <p class="step-title">{s.title}</p>
              <p class="step-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <p class="pato-source">{c.source}</p>
    </div>
  </section>
</BusinessUnitTemplate>

<style>
  .pato-section { background: var(--color-bg); padding-block: var(--space-16); }
  .pato-section .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 720px; }
  .pato-section .section-header { max-width: 720px; margin-bottom: var(--space-12); }
  .pato-cities { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-6); }
  .pato-cities li {
    font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }
  .pato-stats {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-6);
    margin-bottom: var(--space-12);
  }
  .pato-stat {
    text-align: center; padding: var(--space-6);
    background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md);
  }
  .stat-value { font-family: var(--font-display); font-size: var(--fs-3xl); font-weight: 800; color: var(--color-primary-dark); }
  .stat-label { margin-top: var(--space-1); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .pato-flow { max-width: 960px; margin-inline: auto; }
  .flow-svg { width: 100%; height: auto; overflow: visible; }
  .flow-line { stroke: var(--color-border-strong); stroke-width: 2; }
  .node-dot { fill: var(--color-bg); stroke: var(--color-primary); stroke-width: 2; }
  .pulse { fill: var(--color-primary); filter: drop-shadow(0 0 4px var(--color-primary)); }

  .flow-steps { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-4); margin-top: var(--space-4); }
  .step-n { font-family: var(--font-display); font-size: var(--fs-lg); font-weight: 800; color: var(--color-primary); }
  .step-title { margin-top: var(--space-1); font-weight: 700; color: var(--color-text); }
  .step-desc { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .pato-source { margin-top: var(--space-8); font-size: var(--fs-xs); color: var(--color-text-faint); text-align: center; }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
  }
  @media (max-width: 900px) {
    .pato-stats { grid-template-columns: 1fr; }
    .flow-steps { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
  }
  @media (max-width: 560px) {
    .flow-steps { grid-template-columns: 1fr; }
  }
</style>
