---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getBusinessUnits } from "../../../data/businessUnits";
import { useTranslations, localePath, localizePath } from "../../../i18n/utils";
import { defaultLocale, type Locale } from "../../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);
const t = tr.solutions;
const units = getBusinessUnits(lang);
const description = {
  pt: "Conheça as quatro unidades de negócio da Proc: Cidades Inteligentes, Segurança Corporativa, Infraestrutura de TI e IA Industrial.",
  en: "Explore Proc's four business units: Smart Cities, Corporate Security, IT Infrastructure and Industrial AI.",
  es: "Conoce las cuatro unidades de negocio de Proc: Ciudades Inteligentes, Seguridad Corporativa, Infraestructura de TI e IA Industrial.",
}[lang];
---

<BaseLayout title={tr.nav.solucoes} description={description}>
  <div class="container">
    <Breadcrumb
      items={[
        { label: tr.nav.home, href: localePath("/", lang) },
        { label: tr.nav.solucoes, href: localePath("/solucoes", lang) },
      ]}
    />
  </div>
  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{t.indexEyebrow}</p>
      <h1>{t.indexTitle}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container units-grid">
      {units.map((unit) => (
        <a href={localizePath(unit.href, lang)} class="unit-card" data-reveal style={`--unit-color: ${unit.color}`}>
          <span class="unit-badge">{unit.shortName}</span>
          <h2>{unit.name}</h2>
          <p>{unit.tagline}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); }
  .section { padding-block: var(--space-16) var(--space-24); }
  .units-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-6); }
  .unit-card {
    position: relative;
    padding: var(--space-8);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), border-color var(--dur-fast) ease;
    overflow: hidden;
  }
  .unit-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: var(--unit-color);
    background: color-mix(in srgb, var(--unit-color), white 24%);
  }
  .unit-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--unit-color), white 36%); }
  .unit-badge { font-size: var(--fs-xs); font-weight: 700; color: var(--white); text-transform: uppercase; letter-spacing: 0.08em; }
  .unit-card h2 { margin-top: var(--space-2); font-size: var(--fs-xl); }
  .unit-card p { margin-top: var(--space-2); color: var(--color-text-muted); }
  @media (max-width: 640px) { .units-grid { grid-template-columns: 1fr; } }
</style>
