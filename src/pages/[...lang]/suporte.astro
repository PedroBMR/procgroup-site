---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ContactChannels from "../../components/ContactChannels.astro";
import { useTranslations, localePath } from "../../i18n/utils";
import { usePages } from "../../i18n/pages";
import { defaultLocale, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}
const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);
const t = usePages(lang).suporte;
---

<BaseLayout title={t.heroTitle} description={t.metaDescription}>
  <div class="container">
    <Breadcrumb items={[{ label: tr.nav.home, href: localePath("/", lang) }, { label: t.heroTitle, href: localePath("/suporte", lang) }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ContactChannels title={t.channelsTitle} />
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 620px; }
  .section { padding-block: var(--space-8) var(--space-24); }
</style>
