---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Button from "../../components/Button.astro";
import { homeStats } from "../../data/stats";
import { getBusinessUnits } from "../../data/businessUnits";
import hqPhoto from "../../assets/images/hq-pato-branco.webp";
import { WHATSAPP_DEMO } from "../../data/contact";
import { useTranslations, localePath, localizePath } from "../../i18n/utils";
import { usePages } from "../../i18n/pages";
import { defaultLocale, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}
const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);
const t = usePages(lang).empresa;
const statsLabels = tr.home.statsLabels;
const businessUnits = getBusinessUnits(lang);

// Blocos institucionais só-PT (Razão de Existir, Diferencial, Missão/Visão,
// Valores, Compromisso). Guardados na renderização — EN/ES seguem sem eles.
type EmpresaExtra = {
  purposeEyebrow?: string; purposeTitle?: string; purposeParas?: string[];
  differentialEyebrow?: string; differentialTitle?: string; differentialParas?: string[];
  missionEyebrow?: string; missionText?: string; visionEyebrow?: string; visionText?: string;
  principlesEyebrow?: string; principlesTitle?: string; principles?: { title: string; desc: string }[];
  commitmentEyebrow?: string; commitmentTitle?: string; commitmentLead?: string;
  commitmentItems?: string[]; commitmentClose?: string;
};
const e = t as unknown as EmpresaExtra;

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "Empresa Proc Group",
  description: t.metaDescription,
};
---

<BaseLayout title={tr.nav.empresa} description={t.metaDescription} schema={schema}>
  <div class="container">
    <Breadcrumb
      items={[
        { label: tr.nav.home, href: localePath("/", lang) },
        { label: tr.nav.empresa, href: localePath("/empresa", lang) },
      ]}
    />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle}</h1>
      <p class="lead">{t.heroLead}</p>
    </div>
  </section>

  <section class="photo-section">
    <Image src={hqPhoto} alt={t.photoAlt} width={1600} height={720} quality={70} class="hq-photo" />
  </section>

  {e.purposeParas && (
    <section class="section purpose-section">
      <div class="container purpose-inner" data-reveal>
        <p class="eyebrow">{e.purposeEyebrow}</p>
        <h2>{e.purposeTitle}</h2>
        <div class="purpose-body">
          {e.purposeParas.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>
  )}

  <section class="section story-section" data-theme="light">
    <div class="container story-grid">
      <div data-reveal>
        <p class="eyebrow">{t.storyEyebrow}</p>
        <h2>{t.storyTitle}</h2>
        <p class="lead">{t.storyText}</p>
      </div>
      <div class="stats-mini" data-reveal>
        {homeStats.map((stat, i) => (
          <div class="mini-stat">
            <p class="mini-value">{stat.value}{stat.suffix}</p>
            <p class="mini-label">{statsLabels[i]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section timeline-section" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">{t.timelineEyebrow}</p>
        <h2>{t.timelineTitle}</h2>
      </div>
      <div class="timeline-grid">
        {t.timeline.map((item) => (
          <div class="timeline-card" data-reveal>
            <span class="timeline-year">{item.year}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section values-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">{t.valuesEyebrow}</p>
        <h2>{t.valuesTitle}</h2>
      </div>
      <div class="values-grid">
        {t.values.map((v) => (
          <div class="value-card" data-reveal>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {e.differentialParas && (
    <section class="section differential-section" data-theme="light">
      <div class="container differential-inner" data-reveal>
        <div class="differential-copy">
          <p class="eyebrow">{e.differentialEyebrow}</p>
          <h2>{e.differentialTitle}</h2>
        </div>
        <div class="differential-body">
          {e.differentialParas.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>
  )}

  {e.missionText && (
    <section class="section mv-section">
      <div class="container mv-grid">
        <div class="mv-card" data-reveal>
          <p class="eyebrow">{e.missionEyebrow}</p>
          <p class="mv-text">{e.missionText}</p>
        </div>
        <div class="mv-card" data-reveal>
          <p class="eyebrow">{e.visionEyebrow}</p>
          <p class="mv-text">{e.visionText}</p>
        </div>
      </div>
    </section>
  )}

  {e.principles && (
    <section class="section principles-section" data-theme="light">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="eyebrow">{e.principlesEyebrow}</p>
          <h2>{e.principlesTitle}</h2>
        </div>
        <div class="principles-grid">
          {e.principles.map((p) => (
            <div class="principle-card" data-reveal>
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section credibility-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">{t.credEyebrow}</p>
        <h2>{t.credTitle}</h2>
      </div>
      <div class="credibility-grid">
        {t.credibility.map((c) => (
          <div class="credibility-card" data-reveal>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section units-recap" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">{t.unitsEyebrow}</p>
        <h2>{t.unitsTitle}</h2>
      </div>
      <div class="units-grid">
        {businessUnits.map((unit) => (
          <a href={localizePath(unit.href, lang)} class="unit-card" data-reveal style={`--unit-color: ${unit.color}`}>
            <span class="unit-badge">{unit.shortName}</span>
            <h3>{unit.name}</h3>
            <p>{unit.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {e.commitmentItems && (
    <section class="section commitment-section">
      <div class="container">
        <div class="section-header commitment-header" data-reveal>
          <p class="eyebrow">{e.commitmentEyebrow}</p>
          <h2>{e.commitmentTitle}</h2>
          <p class="lead">{e.commitmentLead}</p>
        </div>
        <ul class="commitment-list">
          {e.commitmentItems.map((c) => <li data-reveal>{c}</li>)}
        </ul>
        <p class="commitment-close" data-reveal>{e.commitmentClose}</p>
      </div>
    </section>
  )}

  <section class="section final-cta">
    <div class="container final-cta-inner" data-reveal>
      <h2>{t.finalCtaTitle}</h2>
      <p>{t.finalCtaText}</p>
      <Button href={WHATSAPP_DEMO} variant="primary" size="lg" data-magnetic>{tr.solutions.ctaDemo}</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }

  .photo-section { padding-block: var(--space-8) 0; }
  .hq-photo { width: 100%; max-height: 520px; object-fit: cover; }

  .section { padding-block: var(--space-16); }
  .section-header { max-width: 680px; margin-bottom: var(--space-12); }
  .section-header h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }

  .story-section { background: var(--color-bg); }
  .story-grid { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr); gap: var(--space-16); align-items: center; }
  .story-grid h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }
  .stats-mini { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  .mini-stat { padding: var(--space-6); background: var(--color-bg-alt); border-radius: var(--radius-md); border: 1px solid var(--color-border); }
  .mini-value { font-size: var(--fs-2xl); font-weight: 800; color: var(--color-primary-dark); }
  .mini-label { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .timeline-section { background: var(--color-bg-alt); }
  .timeline-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-6); }
  .timeline-card { padding: var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .timeline-year { font-size: var(--fs-xs); font-weight: 700; color: var(--color-primary-dark); text-transform: uppercase; letter-spacing: 0.06em; }
  .timeline-card h3 { margin-top: var(--space-2); font-size: var(--fs-lg); }
  .timeline-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .values-section { background: var(--navy-900); }
  .values-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-6); }
  .value-card { padding: var(--space-8) var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .value-card h3 { font-size: var(--fs-lg); }
  .value-card p { margin-top: var(--space-3); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .credibility-section { background: var(--color-bg-alt); }
  .credibility-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-6); }
  .credibility-card { padding: var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .credibility-card h3 { font-size: var(--fs-base); }
  .credibility-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .units-recap { background: var(--color-bg); }
  .units-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-6); }
  .unit-card {
    position: relative;
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), border-color var(--dur-fast) ease;
    overflow: hidden;
  }
  .unit-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--unit-color); }
  .unit-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--unit-color), white 36%); }
  .unit-badge { font-size: var(--fs-xs); font-weight: 700; color: var(--unit-color); text-transform: uppercase; letter-spacing: 0.08em; }
  .unit-card h3 { margin-top: var(--space-2); font-size: var(--fs-lg); }
  .unit-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  /* Razão de existir */
  .purpose-section { background: var(--color-bg); }
  .purpose-inner { max-width: 840px; }
  .purpose-inner h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); max-width: 18ch; }
  .purpose-body { margin-top: var(--space-8); display: grid; gap: var(--space-5); }
  .purpose-body p { font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 68ch; line-height: 1.6; }

  /* Nosso diferencial */
  .differential-section { background: var(--color-bg-alt); }
  .differential-inner { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr); gap: var(--space-16); align-items: start; }
  .differential-copy h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }
  .differential-body { display: grid; gap: var(--space-5); }
  .differential-body p { font-size: var(--fs-base); color: var(--color-text-muted); }

  /* Missão & Visão */
  .mv-section { background: var(--color-bg); }
  .mv-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: var(--space-6); }
  .mv-card {
    padding: var(--space-8);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
  }
  .mv-text { margin-top: var(--space-4); font-size: var(--fs-lg); color: var(--color-text); line-height: 1.5; }

  /* Nossos valores */
  .principles-section { background: var(--color-bg); }
  .principles-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-6); }
  .principle-card {
    padding: var(--space-6) var(--space-6) var(--space-8);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
  }
  .principle-card h3 { font-size: var(--fs-lg); }
  .principle-card p { margin-top: var(--space-3); font-size: var(--fs-sm); color: var(--color-text-muted); }

  /* Compromisso com a sociedade */
  .commitment-section { background: var(--navy-900); }
  .commitment-header { max-width: 720px; margin-bottom: var(--space-8); }
  .commitment-header h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); color: var(--white); }
  .commitment-header .lead { color: rgba(255,255,255,0.75); }
  .commitment-list { display: grid; gap: var(--space-4); max-width: 860px; }
  .commitment-list li {
    position: relative; padding-left: var(--space-8);
    font-size: var(--fs-base); color: rgba(255,255,255,0.85); line-height: 1.5;
  }
  .commitment-list li::before {
    content: ""; position: absolute; left: 0; top: 0.5em;
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--red-500); box-shadow: 0 0 0 4px rgba(226,8,29,0.18);
  }
  .commitment-close {
    margin-top: var(--space-12); max-width: 780px;
    font-size: var(--fs-lg); font-weight: 600; color: var(--white); line-height: 1.5;
  }

  .final-cta {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-800));
    color: var(--white);
    text-align: center;
  }
  .final-cta-inner h2 { color: var(--white); font-size: var(--fs-3xl); max-width: 680px; margin-inline: auto; }
  .final-cta-inner p { margin-top: var(--space-4); color: rgba(255,255,255,0.75); }
  .final-cta-inner .btn { margin-top: var(--space-8); }

  @media (max-width: 980px) {
    .story-grid { grid-template-columns: 1fr; }
    .values-grid, .units-grid, .timeline-grid, .credibility-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
    .differential-inner, .mv-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    .principles-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
  }
  @media (max-width: 640px) {
    .values-grid, .units-grid, .stats-mini, .timeline-grid, .credibility-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr; }
  }
</style>
