---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ContactChannels from "../../components/ContactChannels.astro";
import { withBase } from "../../utils/url";
import { getBusinessUnits } from "../../data/businessUnits";
import { useTranslations, localePath } from "../../i18n/utils";
import { usePages } from "../../i18n/pages";
import { defaultLocale, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: "en" } }, { params: { lang: "es" } }];
}
const lang = (Astro.params.lang as Locale) || defaultLocale;
const tr = useTranslations(lang);
const t = usePages(lang).contato;
const interests = getBusinessUnits(lang).map((u) => u.name);
---

<BaseLayout title={tr.nav.contato} description={t.metaDescription}>
  <div class="container">
    <Breadcrumb
      items={[
        { label: tr.nav.home, href: localePath("/", lang) },
        { label: tr.nav.contato, href: localePath("/contato", lang) },
      ]}
    />
  </div>
  <section class="contact-hero">
    <div class="container">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitleDefault}</h1>
      <p class="lead">{t.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="container form-grid">
      <form
        class="contact-form"
        method="post"
        action={withBase("/contact.php")}
        data-contact-form
        data-sending={t.sending}
        data-success={t.statusSuccess}
        data-error={t.statusError}
        data-server-msg={lang === defaultLocale ? "1" : undefined}
      >
        <p class="form-status" data-form-status role="status" aria-live="polite" hidden></p>

        <label class="honeypot" aria-hidden="true">
          {t.honeypot}
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>

        <label>
          {t.labelName}
          <input type="text" name="name" required />
        </label>
        <label>
          {t.labelEmail}
          <input type="email" name="email" required />
        </label>
        <label>
          {t.labelProfile}
          <select name="profile">
            {t.profileOptions.map((opt) => <option>{opt}</option>)}
          </select>
        </label>
        <label>
          {t.labelOrg}
          <input type="text" name="organization" />
        </label>
        <label>
          {t.labelInterest}
          <select name="interest">
            {interests.map((opt) => <option>{opt}</option>)}
          </select>
        </label>
        <label>
          {t.labelMessage}
          <textarea name="message" rows="4"></textarea>
        </label>
        <button type="submit" class="submit-btn">{t.submit}</button>
      </form>
      <ContactChannels />
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLElement>("[data-form-status]");
  const MSG = {
    sending: form?.dataset.sending || "…",
    success: form?.dataset.success || "",
    error: form?.dataset.error || "",
  };

  // O contact.php devolve mensagens específicas ("Informe um e-mail válido",
  // "Não foi possível enviar agora…") — bem mais úteis que um erro genérico.
  // Mas elas só existem em português, então só são exibidas no site PT; EN/ES
  // ficam com a mensagem traduzida.
  const useServerMsg = form?.dataset.serverMsg === "1";
  const statusText = (result: { ok: boolean; message?: string }) =>
    useServerMsg && result.message ? result.message : result.ok ? MSG.success : MSG.error;

  // A página é pré-renderizada estática, então searchParams do servidor não veem
  // a query real do visitante (ex.: depois do redirect sem-JS do contact.php).
  // Ler location.search no cliente é a única forma de refletir o que aconteceu.
  const params = new URLSearchParams(location.search);
  if (status && (params.has("enviado") || params.has("erro"))) {
    const ok = params.get("enviado") === "1";
    status.textContent = ok ? MSG.success : MSG.error;
    status.classList.add(ok ? "is-success" : "is-error");
    status.hidden = false;
    history.replaceState(null, "", location.pathname);
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const submitBtn = form.querySelector<HTMLButtonElement>(".submit-btn");
    if (!status || !submitBtn) return;

    submitBtn.disabled = true;
    const originalLabel = submitBtn.textContent;
    submitBtn.textContent = MSG.sending;
    status.hidden = true;
    status.classList.remove("is-success", "is-error");

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      const result = await response.json();
      status.textContent = statusText(result);
      status.classList.add(result.ok ? "is-success" : "is-error");
      status.hidden = false;
      if (result.ok) form.reset();
    } catch {
      status.textContent = MSG.error;
      status.classList.add("is-error");
      status.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
    }
  });
</script>

<style>
  .contact-hero { padding-block: var(--space-16) var(--space-8); }
  .contact-hero h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 560px; }
  .section { padding-block: var(--space-8) var(--space-24); }
  .form-grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); gap: var(--space-16); align-items: start; }
  .contact-form { display: grid; gap: var(--space-4); }
  .contact-form label { display: grid; gap: var(--space-2); font-size: var(--fs-sm); font-weight: 600; color: var(--color-text); }
  .contact-form input, .contact-form select, .contact-form textarea {
    font: inherit; padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .contact-form input::placeholder, .contact-form textarea::placeholder { color: var(--color-text-faint); }
  .contact-form textarea { resize: vertical; min-height: 140px; }
  .contact-form select option { background: var(--surface-1); color: var(--color-text); }
  .contact-form input:focus, .contact-form select:focus, .contact-form textarea:focus {
    outline: 2px solid var(--color-primary); outline-offset: 1px;
  }
  .submit-btn {
    justify-self: start; background: var(--color-primary); color: var(--white);
    border: none; padding: 0.9rem 2rem; border-radius: var(--radius-pill); font-weight: 700;
    transition: background var(--dur-fast) ease;
  }
  .submit-btn:hover { background: var(--color-primary-dark); }
  .submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }

  .honeypot { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }

  .form-status {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: 600;
  }
  .form-status.is-success { background: var(--color-success-bg); color: var(--color-success); border: 1px solid rgba(22, 163, 74, 0.3); }
  .form-status.is-error { background: var(--color-danger-bg); color: var(--color-danger); border: 1px solid var(--color-danger-border); }
  @media (max-width: 840px) { .form-grid { grid-template-columns: 1fr; } }
</style>
