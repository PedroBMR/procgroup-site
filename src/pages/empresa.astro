---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Button from "../components/Button.astro";
import StatCounter from "../components/StatCounter.astro";
import { homeStats } from "../data/stats";
import { businessUnits } from "../data/businessUnits";
import hqPhoto from "../assets/images/hq-pato-branco.webp";

const values = [
  { title: "Visão consultiva e preventiva", desc: "Atuamos antes que o problema aconteça, não apenas reagindo a incidentes." },
  { title: "Tecnologia confiável", desc: "Cloud certificada, IA aplicada e integração com órgãos oficiais de segurança." },
  { title: "Entrega completa", desc: "Infraestrutura, monitoramento, suporte e inteligência em uma só plataforma." },
  { title: "Compromisso social", desc: "Soluções que protegem comunidades e fortalecem o poder público." },
];

const timeline = [
  { year: "2014", title: "Fundação", desc: "Fundada em Pato Branco (PR), com foco em infraestrutura de TI para supermercados." },
  { year: "2016–2018", title: "Consolidação", desc: "Consolidação em soluções de cloud, backup e suporte completo." },
  { year: "2019", title: "Expansão", desc: "Expansão para o setor público, com projetos pioneiros em câmeras inteligentes e reconhecimento facial." },
  { year: "Hoje", title: "Presente", desc: "Presença crescente em todo o Sul do Brasil, evoluindo de duas frentes sólidas para quatro unidades especializadas." },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "Empresa Proc Group",
  description: "Conheça a história, a missão e os valores da Proc Group.",
};
---

<BaseLayout
  title="Empresa"
  description="Conheça a Proc Group: uma empresa de tecnologia que desenvolve sua própria plataforma de Inteligência Artificial para cidades, empresas e indústrias."
  schema={schema}
>
  <div class="container">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Empresa", href: "/empresa" }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">Empresa</p>
      <h1>Uma empresa de tecnologia. Não uma integradora.</h1>
      <p class="lead">
        Fundada em 2014 em Pato Branco (PR), a Proc nasceu para atender as necessidades específicas do varejo
        alimentar em infraestrutura de TI. Hoje desenvolvemos nossa própria plataforma de Inteligência Artificial,
        Visão Computacional e Infraestrutura de TI — mantendo equipes altamente especializadas em cada segmento
        de atuação.
      </p>
    </div>
  </section>

  <section class="photo-section">
    <Image src={hqPhoto} alt="Sede da Proc Group em Pato Branco" width={1600} height={720} quality={70} class="hq-photo" />
  </section>

  <section class="section story-section" data-theme="light">
    <div class="container story-grid">
      <div data-reveal>
        <p class="eyebrow">Nossa história</p>
        <h2>Uma plataforma. Múltiplas soluções. Uma única inteligência.</h2>
        <p class="lead">
          Desde o primeiro projeto, acreditamos que inovação de verdade acontece quando a tecnologia serve às
          pessoas — melhorando processos, garantindo segurança, fortalecendo negócios e contribuindo para o bem
          comum. Em 2019 ampliamos nossa atuação para o setor público, criando soluções que hoje fazem parte da
          rotina de prefeituras, forças de segurança e aeroportos. Hoje a Proc não é apenas uma integradora de
          tecnologias — é uma empresa que desenvolve sua própria plataforma de Inteligência Artificial, com
          equipes especializadas em Cidades Inteligentes, Segurança Corporativa, Infraestrutura de TI e IA
          Industrial.
        </p>
      </div>
      <div class="stats-mini" data-reveal>
        {homeStats.slice(0, 4).map((stat) => (
          <div class="mini-stat">
            <p class="mini-value">{stat.value}{stat.suffix}</p>
            <p class="mini-label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section timeline-section" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Nossa trajetória</p>
        <h2>Mais de uma década construindo tecnologia com propósito</h2>
      </div>
      <div class="timeline-grid">
        {timeline.map((t) => (
          <div class="timeline-card" data-reveal>
            <span class="timeline-year">{t.year}</span>
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section values-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">O que nos diferencia</p>
        <h2>O que guia o trabalho da Proc</h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card" data-reveal>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section credibility-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Credibilidade</p>
        <h2>Reconhecida por empresas e autoridades públicas</h2>
      </div>
      <div class="credibility-grid">
        <div class="credibility-card" data-reveal>
          <h3>Embarque + Seguro</h3>
          <p>Parceiros oficiais do programa do Governo Federal.</p>
        </div>
        <div class="credibility-card" data-reveal>
          <h3>Órgãos de segurança</h3>
          <p>Tecnologias utilizadas por forças de segurança de diversas cidades.</p>
        </div>
        <div class="credibility-card" data-reveal>
          <h3>Grandes players</h3>
          <p>Projetos realizados para grandes players, como Latam Linhas Aéreas.</p>
        </div>
        <div class="credibility-card" data-reveal>
          <h3>Equipes certificadas</h3>
          <p>Operação de ambientes críticos com excelência.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section units-recap" data-theme="light">
    <div class="container">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Onde atuamos</p>
        <h2>Quatro unidades de negócio, uma única plataforma</h2>
      </div>
      <div class="units-grid">
        {businessUnits.map((unit) => (
          <a href={unit.href} class="unit-card" data-reveal style={`--unit-color: ${unit.color}`}>
            <span class="unit-badge">{unit.shortName}</span>
            <h3>{unit.name}</h3>
            <p>{unit.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner" data-reveal>
      <h2>Quer conhecer a Proc de perto?</h2>
      <p>Fale com um de nossos especialistas e descubra como podemos ajudar sua operação.</p>
      <Button href="/contato?intent=demo" variant="primary" size="lg">Solicitar Demonstração</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }

  .photo-section { padding-block: var(--space-8) 0; }
  .hq-photo { width: 100%; max-height: 520px; object-fit: cover; }

  .section { padding-block: var(--space-16); }
  .section-header { max-width: 680px; margin-bottom: var(--space-12); }
  .section-header h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }

  .story-section { background: var(--color-bg); }
  .story-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--space-16); align-items: center; }
  .story-grid h2 { margin-top: var(--space-4); font-size: var(--fs-3xl); }
  .stats-mini { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  .mini-stat { padding: var(--space-6); background: var(--color-bg-alt); border-radius: var(--radius-md); border: 1px solid var(--color-border); }
  .mini-value { font-size: var(--fs-2xl); font-weight: 800; color: var(--red-500); }
  .mini-label { margin-top: var(--space-1); font-size: var(--fs-xs); color: var(--color-text-muted); }

  .timeline-section { background: var(--color-bg-alt); }
  .timeline-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .timeline-card { padding: var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .timeline-year { font-size: var(--fs-xs); font-weight: 700; color: var(--red-500); text-transform: uppercase; letter-spacing: 0.06em; }
  .timeline-card h3 { margin-top: var(--space-2); font-size: var(--fs-lg); }
  .timeline-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .values-section { background: var(--navy-900); }
  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .value-card { padding: var(--space-8) var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .value-card h3 { font-size: var(--fs-lg); }
  .value-card p { margin-top: var(--space-3); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .credibility-section { background: var(--color-bg-alt); }
  .credibility-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .credibility-card { padding: var(--space-6); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border); }
  .credibility-card h3 { font-size: var(--fs-base); }
  .credibility-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .units-recap { background: var(--color-bg); }
  .units-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .unit-card {
    position: relative;
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), border-color var(--dur-fast) ease;
    overflow: hidden;
  }
  .unit-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--unit-color); }
  .unit-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: var(--unit-color); }
  .unit-badge { font-size: var(--fs-xs); font-weight: 700; color: var(--unit-color); text-transform: uppercase; letter-spacing: 0.08em; }
  .unit-card h3 { margin-top: var(--space-2); font-size: var(--fs-lg); }
  .unit-card p { margin-top: var(--space-2); font-size: var(--fs-sm); color: var(--color-text-muted); }

  .final-cta {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-800));
    color: var(--white);
    text-align: center;
  }
  .final-cta-inner h2 { color: var(--white); font-size: var(--fs-3xl); max-width: 680px; margin-inline: auto; }
  .final-cta-inner p { margin-top: var(--space-4); color: rgba(255,255,255,0.75); }
  .final-cta-inner .btn { margin-top: var(--space-8); }

  @media (max-width: 980px) {
    .story-grid { grid-template-columns: 1fr; }
    .values-grid, .units-grid, .timeline-grid, .credibility-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .values-grid, .units-grid, .stats-mini, .timeline-grid, .credibility-grid { grid-template-columns: 1fr; }
  }
</style>
