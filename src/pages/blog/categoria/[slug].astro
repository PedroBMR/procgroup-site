---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import PostCard from "../../../components/PostCard.astro";
import {
  collectCategories,
  postsInCategory,
  categoryColor,
  CATCH_ALL_CATEGORY,
  EVENTS_CATEGORY,
  type BlogPost,
  type BlogCategory,
} from "../../../utils/blog";
import { withBase } from "../../../utils/url";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  // Catch-all lives at /blog; Eventos has its own /eventos page.
  const categories = collectCategories(posts).filter(
    (c) => c.slug !== CATCH_ALL_CATEGORY && c.slug !== EVENTS_CATEGORY,
  );
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category, posts: postsInCategory(posts, category.slug) },
  }));
}

interface Props {
  category: BlogCategory;
  posts: BlogPost[];
}

const { category, posts } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: `${category.name} | Blog Proc Group`,
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    datePublished: post.data.date.toISOString(),
    url: new URL(`/blog/${post.data.slug}`, "https://www.procgroup.com.br").toString(),
  })),
};
---

<BaseLayout
  title={`${category.name} — Blog`}
  description={`Conteúdo da Proc Group sobre ${category.name}.`}
  schema={schema}
>
  <div class="container">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog" },
        { label: category.name, href: `/blog/categoria/${category.slug}` },
      ]}
    />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow" style={`color: ${categoryColor(category.slug)}`}>Categoria</p>
      <h1>{category.name}</h1>
      <p class="lead">{posts.length} {posts.length === 1 ? "publicação" : "publicações"} nesta categoria.</p>
    </div>
  </section>

  <section class="section posts-section" data-theme="light">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); }
  .section { padding-block: var(--space-16) var(--space-24); }
  .posts-section { background: var(--color-bg); }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 980px) { .posts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
