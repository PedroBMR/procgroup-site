---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { businessUnits } from "../../data/businessUnits";

import cidadesAeroportuaria from "../../assets/images/blog/cidades-seguranca-aeroportuaria.webp";
import cidadesCoi from "../../assets/images/blog/cidades-02.png";
import segurancaLgpd from "../../assets/images/blog/seguranca-facial-lgpd.webp";
import segurancaAcesso from "../../assets/images/blog/seguranca-05.png";
import infraCloud from "../../assets/images/blog/infra-cloud-vs-local.webp";
import infraSre from "../../assets/images/blog/infra-sre-observabilidade.webp";
import industrialVisao from "../../assets/images/blog/industrial-01.png";
import industrialEdge from "../../assets/images/blog/industrial-06.png";

const posts = [
  {
    slug: "cidades-inteligentes",
    unit: businessUnits[0],
    title: "Segurança aeroportuária inteligente: como a IA está mudando o setor",
    excerpt: "Reconhecimento facial, analytics e videomonitoramento integrado estão redefinindo a segurança em aeroportos.",
    image: cidadesAeroportuaria,
  },
  {
    slug: "cidades-inteligentes",
    unit: businessUnits[0],
    title: "Centros de Operações integrados: o que aprendemos implantando dezenas deles",
    excerpt: "Lições práticas de projetos de Centro Integrado de Operações em municípios de diferentes portes.",
    image: cidadesCoi,
  },
  {
    slug: "seguranca-corporativa",
    unit: businessUnits[1],
    title: "Reconhecimento facial e LGPD: como conciliar segurança e conformidade",
    excerpt: "O que empresas precisam considerar ao adotar reconhecimento facial dentro da legislação brasileira.",
    image: segurancaLgpd,
  },
  {
    slug: "seguranca-corporativa",
    unit: businessUnits[1],
    title: "Controle de acesso facial: o fim das catracas com cartão?",
    excerpt: "Como o reconhecimento facial está substituindo credenciais físicas em ambientes corporativos e industriais.",
    image: segurancaAcesso,
  },
  {
    slug: "infraestrutura-de-ti",
    unit: businessUnits[2],
    title: "Cloud gerenciada vs. servidor local: qual escolher em 2026?",
    excerpt: "Um comparativo prático de custo, performance e governança entre os dois modelos de infraestrutura.",
    image: infraCloud,
  },
  {
    slug: "infraestrutura-de-ti",
    unit: businessUnits[2],
    title: "SRE e observabilidade no varejo: lições de quem opera em escala",
    excerpt: "Como práticas de SRE reduzem indisponibilidade em operações de varejo com alta sazonalidade.",
    image: infraSre,
  },
  {
    slug: "ia-industrial",
    unit: businessUnits[3],
    title: "Visão computacional na linha de produção: por onde começar",
    excerpt: "Um guia prático para implantar inspeção visual automatizada sem parar a produção.",
    image: industrialVisao,
  },
  {
    slug: "ia-industrial",
    unit: businessUnits[3],
    title: "Edge AI na indústria: processamento em tempo real na borda",
    excerpt: "Por que processar IA na borda reduz latência e amplia a autonomia de linhas de produção.",
    image: industrialEdge,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog Proc Group",
  description: "Conteúdo sobre Cidades Inteligentes, Segurança Corporativa, Infraestrutura de TI e IA Industrial.",
};
---

<BaseLayout
  title="Blog"
  description="Conteúdo sobre Cidades Inteligentes, Segurança Corporativa, Infraestrutura de TI e IA Industrial, direto dos especialistas da Proc Group."
  schema={schema}
>
  <div class="container">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog", href: "/blog" }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>Ideias e bastidores da Proc AI Platform</h1>
      <p class="lead">Conteúdo dividido nas quatro áreas de atuação da Proc.</p>
      <div class="category-chips">
        {businessUnits.map((unit) => (
          <a href={`/solucoes/${unit.slug}`} class="chip" style={`--unit-color: ${unit.color}`}>{unit.shortName}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section posts-section" data-theme="light">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/solucoes/${post.slug}`} class="post-card" data-reveal style={`--unit-color: ${post.unit.color}`}>
            <div class="post-image">
              <Image src={post.image} alt={post.title} width={480} height={280} quality={65} />
            </div>
            <div class="post-body">
              <span class="post-category">{post.unit.name}</span>
              <h2>{post.title}</h2>
              <p>{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }

  .category-chips { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-8); }
  .chip {
    font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    border: 1px solid var(--unit-color);
    color: var(--unit-color);
    transition: background var(--dur-fast) ease, color var(--dur-fast) ease;
  }
  .chip:hover { background: var(--unit-color); color: var(--white); }

  .section { padding-block: var(--space-16) var(--space-24); }
  .posts-section { background: var(--color-bg); }

  .posts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  .post-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  .post-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
  .post-image { aspect-ratio: 16/9; overflow: hidden; }
  .post-image :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .post-body { padding: var(--space-5); }
  .post-category { font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--unit-color); }
  .post-card h2 {
    margin-top: var(--space-2);
    font-size: var(--fs-base);
    font-family: var(--font-sans);
    text-transform: none;
    font-weight: 700;
    line-height: var(--lh-snug);
  }
  .post-card p { margin-top: var(--space-2); font-size: var(--fs-xs); color: var(--color-text-muted); }

  @media (max-width: 980px) {
    .posts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
