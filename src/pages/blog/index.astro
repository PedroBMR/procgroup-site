---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import {
  byNewest,
  categoryColor,
  categoryHref,
  collectCategories,
  formatDate,
  isoDate,
  CATCH_ALL_CATEGORY,
} from "../../utils/blog";
import { withBase } from "../../utils/url";

const posts = (await getCollection("blog")).sort(byNewest);
const [featured, ...rest] = posts;

// Chips: real WP categories (minus the catch-all that sits on every post).
const categories = collectCategories(posts)
  .filter((c) => c.slug !== CATCH_ALL_CATEGORY)
  .sort((a, b) => a.name.localeCompare(b.name, "pt-BR"));

function primaryCategory(cats: { slug: string; name: string }[]) {
  return cats.find((c) => c.slug !== CATCH_ALL_CATEGORY) ?? cats[0];
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog Proc Group",
  description: "Conteúdo sobre segurança pública, segurança corporativa, infraestrutura de TI e tecnologia.",
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    datePublished: post.data.date.toISOString(),
    url: new URL(`/blog/${post.data.slug}`, "https://www.procgroup.com.br").toString(),
  })),
};
---

<BaseLayout
  title="Blog"
  description="Novidades, eventos e conteúdo técnico da Proc Group sobre segurança pública, segurança corporativa, infraestrutura de TI e inteligência artificial."
  schema={schema}
>
  <div class="container">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog", href: "/blog" }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>Novidades, eventos e tecnologia</h1>
      <p class="lead">Conteúdo direto dos especialistas da Proc Group.</p>
      {categories.length > 0 && (
        <div class="category-chips">
          <span class="chip is-active">Todos</span>
          {categories.map((cat) => (
            <a href={withBase(categoryHref(cat.slug))} class="chip" style={`--unit-color: ${categoryColor(cat.slug)}`}>
              {cat.name}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="section posts-section" data-theme="light">
    <div class="container">
      {featured && (
        <a
          href={withBase(`/blog/${featured.data.slug}`)}
          class="feature-card"
          data-reveal
          style={`--unit-color: ${categoryColor(primaryCategory(featured.data.categories)?.slug)}`}
        >
          {featured.data.image && (
            <div class="feature-image">
              <img src={featured.data.image.src} alt={featured.data.image.alt} width={760} height={480} loading="eager" />
            </div>
          )}
          <div class="feature-body">
            <div class="feature-meta">
              {primaryCategory(featured.data.categories) && (
                <span class="post-category">{primaryCategory(featured.data.categories).name}</span>
              )}
              <time datetime={isoDate(featured.data.date)}>{formatDate(featured.data.date)}</time>
            </div>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.excerpt}</p>
            <span class="read-more">Ler artigo →</span>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <div class="posts-grid">
          {rest.map((post) => {
            const cat = primaryCategory(post.data.categories);
            return (
              <a
                href={withBase(`/blog/${post.data.slug}`)}
                class="post-card"
                data-reveal
                style={`--unit-color: ${categoryColor(cat?.slug)}`}
              >
                {post.data.image && (
                  <div class="post-image">
                    <img src={post.data.image.src} alt={post.data.image.alt} width={480} height={280} loading="lazy" />
                  </div>
                )}
                <div class="post-body">
                  <div class="post-meta">
                    {cat && <span class="post-category">{cat.name}</span>}
                    <time datetime={isoDate(post.data.date)}>{formatDate(post.data.date)}</time>
                  </div>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.excerpt}</p>
                </div>
              </a>
            );
          })}
        </div>
      )}

      {posts.length === 0 && (
        <p class="empty">Nenhum post publicado ainda. Volte em breve.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }

  .category-chips { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-8); }
  .chip {
    font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    padding: var(--space-2) var(--space-4); border-radius: 999px;
    border: 1px solid var(--unit-color, var(--color-border-strong)); color: var(--white);
    transition: background var(--dur-fast) ease, color var(--dur-fast) ease;
  }
  .chip.is-active { background: var(--white); color: var(--navy-900); border-color: var(--white); }
  .chip:not(.is-active):hover { background: var(--unit-color); color: var(--white); }

  .section { padding-block: var(--space-16) var(--space-24); }
  .posts-section { background: var(--color-bg); }

  .feature-card {
    display: grid; grid-template-columns: 1.15fr 1fr; gap: 0;
    border-radius: var(--radius-lg); overflow: hidden; margin-bottom: var(--space-12);
    background: var(--color-bg-alt); border: 1px solid var(--color-border);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  .feature-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  /* If the featured post has no image, the image column is never rendered — drop
     to a single column so the body doesn't leave an empty half. */
  .feature-card:not(:has(.feature-image)) { grid-template-columns: 1fr; }
  .feature-image { overflow: hidden; min-height: 320px; }
  .feature-image img { width: 100%; height: 100%; object-fit: cover; }
  .feature-body { padding: var(--space-8); display: flex; flex-direction: column; justify-content: center; }
  .feature-meta, .post-meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3); }
  .feature-body h2 { margin-top: var(--space-3); font-size: var(--fs-2xl); font-family: var(--font-display); line-height: var(--lh-snug); }
  .feature-body p { margin-top: var(--space-4); font-size: var(--fs-base); color: var(--color-text-muted); }
  .read-more { margin-top: var(--space-6); font-weight: 700; font-size: var(--fs-sm); color: var(--unit-color); }

  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .post-card {
    border-radius: var(--radius-md); overflow: hidden;
    background: var(--color-bg-alt); border: 1px solid var(--color-border);
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  .post-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
  .post-image { aspect-ratio: 16/9; overflow: hidden; }
  .post-image img { width: 100%; height: 100%; object-fit: cover; }
  .post-body { padding: var(--space-5); }
  .post-category { font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--unit-color); }
  .post-meta time, .feature-meta time { font-size: var(--fs-xs); color: var(--color-text-faint); }
  .post-card h2 {
    margin-top: var(--space-2); font-size: var(--fs-base); font-family: var(--font-sans);
    text-transform: none; font-weight: 700; line-height: var(--lh-snug);
  }
  .post-card p { margin-top: var(--space-2); font-size: var(--fs-xs); color: var(--color-text-muted); }
  .empty { color: var(--color-text-muted); font-size: var(--fs-lg); }

  @media (max-width: 980px) {
    .posts-grid { grid-template-columns: 1fr 1fr; }
    .feature-card { grid-template-columns: 1fr; }
    /* min-height + aspect-ratio conflict: the min-height forced the height, and
       aspect-ratio then derived the WIDTH from it (220 x 16/9 = 391px), overflowing
       the cell on mobile. Let aspect-ratio derive height from the full width instead. */
    .feature-image { min-height: 0; aspect-ratio: 16/9; }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
