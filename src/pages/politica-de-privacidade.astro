---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ComingSoon from "../components/ComingSoon.astro";
import { formatDate } from "../utils/blog";

const page = await getEntry("pages", "politica-de-privacidade");
const { Content } = page ? await render(page) : { Content: undefined };
---

<BaseLayout
  title="Política de Privacidade"
  description="Saiba como a Proc Group coleta, usa e protege seus dados pessoais, em conformidade com a LGPD."
>
  <div class="container">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Política de Privacidade", href: "/politica-de-privacidade" }]} />
  </div>

  {page && Content ? (
    <article class="policy">
      <header class="policy-head container">
        <p class="eyebrow">Legal</p>
        <h1>{page.data.title}</h1>
        <p class="updated">Última atualização: {formatDate(page.data.modified)}</p>
      </header>
      <section class="section" data-theme="light">
        <div class="container">
          <div class="prose">
            <Content />
          </div>
        </div>
      </section>
    </article>
  ) : (
    <ComingSoon
      eyebrow="Legal"
      title="Política de Privacidade"
      description="Não foi possível carregar o documento de política de privacidade do WordPress neste build."
    />
  )}
</BaseLayout>

<style>
  .policy-head { padding-block: var(--space-16) var(--space-8); max-width: 820px; }
  .policy-head h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); line-height: var(--lh-snug); }
  .updated { margin-top: var(--space-4); font-size: var(--fs-sm); color: var(--color-text-faint); }
  .section { padding-block: var(--space-8) var(--space-24); background: var(--color-bg); }
</style>
