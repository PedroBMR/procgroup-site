---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PostCard from "../components/PostCard.astro";
import { postsInCategory, EVENTS_CATEGORY } from "../utils/blog";

const posts = postsInCategory(await getCollection("blog"), EVENTS_CATEGORY);

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Agenda de Eventos | Proc Group",
  description: "Eventos, feiras e encontros com participação da Proc Group.",
};
---

<BaseLayout
  title="Agenda de Eventos"
  description="Acompanhe os eventos, feiras e encontros de tecnologia e segurança com participação da Proc Group."
  schema={schema}
>
  <div class="container">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Agenda de Eventos", href: "/eventos" }]} />
  </div>

  <section class="hero-page">
    <div class="container">
      <p class="eyebrow">Agenda</p>
      <h1>Agenda de Eventos</h1>
      <p class="lead">Feiras, encontros e eventos de tecnologia e segurança com a participação da Proc Group.</p>
    </div>
  </section>

  <section class="section posts-section" data-theme="light">
    <div class="container">
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="empty">Nenhum evento na agenda no momento. Volte em breve.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page { padding-block: var(--space-16) var(--space-8); }
  .hero-page h1 { font-size: var(--fs-4xl); margin-top: var(--space-4); max-width: 780px; }
  .lead { margin-top: var(--space-6); font-size: var(--fs-lg); color: var(--color-text-muted); max-width: 640px; }
  .section { padding-block: var(--space-16) var(--space-24); }
  .posts-section { background: var(--color-bg); }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .empty { color: var(--color-text-muted); font-size: var(--fs-lg); }
  @media (max-width: 980px) { .posts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
